---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'How long does assembly really take?',
    a: 'A single cabinet box assembles in about 2-3 minutes. A full set of cabinets assembles in less than 1 hour. Panels push together and lock — then you drive a few screws through the back panel runners to secure it.',
  },
  {
    q: 'What tools do I need?',
    a: "The cabinet box itself locks together without any tools. The only tool you'll need is a screwdriver to secure the back panel through the runners. If you want to wall-mount cabinets, you'll also need a drill for the wall anchors. Hardware such as hinges and drawer glides come with screws that need to be turned in.",
  },
  {
    q: 'How much weight can the cabinets hold?',
    a: 'Each cabinet holds up to 500 lbs. Drawers have a 99 lb weight-bearing capacity.',
  },
  {
    q: 'Are the cabinets moisture-resistant?',
    a: "Yes. Every exposed edge is sealed with 1mm PVC edgebanding, creating a moisture-resistant design that handles garage conditions — temperature swings, humidity, condensation. Combined with scratch-resistant laminate surfaces, they're built to last.",
  },
  {
    q: "Won't kitchen cabinets work in my garage?",
    a: 'Kitchen cabinets are 24" deep — too deep for most garages and built for a clean, climate-controlled environment. Klovo cabinets are 18" deep, built specifically for garage conditions with moisture-resistant sealed edgebanding, and require no external hardware like handles or pulls.',
  },
  {
    q: 'Where are Klovo cabinets made?',
    a: '100% Made in USA. Klovo is built by Door Kraft, a US cabinet manufacturer with 20 years of experience.',
  },
  {
    q: 'Can I buy directly from Klovo?',
    a: 'Klovo cabinets are available through select retailers. Visit Where to Buy to find a retailer near you.',
  },
  {
    q: 'Can I buy individual cabinets or only sets?',
    a: 'Klovo is sold as pre-designed sets — tall, base, and wall cabinets configured for a specific space and use case. This keeps pricing simple and guarantees the set works together.',
  },
  {
    q: "What's the warranty?",
    a: '1-year limited warranty covering defects in materials and workmanship.',
  },
  {
    q: 'Can I disassemble and move the cabinets?',
    a: 'Yes. The same connector system that makes assembly fast also makes disassembly easy. If you move, your Klovo cabinets move with you.',
  },
  {
    q: 'What finishes are available?',
    a: 'Premium white finish. Additional finishes are in development.',
  },
  {
    q: 'How is Klovo different from metal garage cabinets?',
    a: "Metal cabinets are utilitarian — built for the mechanic's shop. Klovo cabinets have a premium furniture-grade finish with scratch-resistant laminate and moisture-resistant sealed edgebanding. Push-to-open doors and drawers give a clean, handle-free look.",
  },
];
---

<BaseLayout title="FAQ" description="Frequently asked questions about Klovo garage cabinet sets. Assembly, weight capacity, materials, warranty, and more.">

  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">FAQ</p>
          <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4">Got questions?</h1>
          <p class="text-lg text-klovo-grey">We've got answers. If yours isn't here, <a href="/contact/" class="text-klovo-blue hover:text-klovo-blue-dark underline">reach out</a>.</p>
        </div>

        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <details class="group bg-warm-neutral rounded-lg reveal" style={`transition-delay: ${i * 50}ms`}>
              <summary class="flex items-center justify-between cursor-pointer p-6 text-lg font-semibold text-charcoal hover:text-klovo-blue transition-colors list-none">
                <span>{faq.q}</span>
                <svg class="w-5 h-5 text-klovo-grey flex-shrink-0 ml-4 group-open:rotate-180 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <div class="px-6 pb-6 text-charcoal/70 leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 lg:py-16 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-2xl font-bold text-charcoal mb-4">Still have questions?</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="btn-primary">Contact Us</a>
        <a href="/where-to-buy/" class="btn-secondary">Find a Retailer</a>
      </div>
    </div>
  </section>

</BaseLayout>
