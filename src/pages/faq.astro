---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'How long does assembly really take?',
    a: 'A full set of cabinets assembles in under an hour. Our unique connector system locks panels together with a simple press — then you drive a few screws through the back panel runners to secure it. That\'s it.',
  },
  {
    q: 'What tools do I need?',
    a: 'The cabinet box itself locks together without any tools — panels press and click into place. The only tool you\'ll need is a screwdriver to secure the back panel through the runners. If you want to wall-mount cabinets, you\'ll need a drill for the wall anchors.',
  },
  {
    q: 'How much weight can the cabinets hold?',
    a: 'Each cabinet holds up to 500 lbs. Drawers have a 99 lb weight-bearing capacity. We\'ve tested them — they didn\'t flinch.',
  },
  {
    q: 'Are the cabinets moisture-proof?',
    a: 'Yes. Every edge is sealed with 1mm PVC edgebanding, creating a moisture-proof design that handles garage conditions — temperature swings, humidity, condensation. Combined with scratch-resistant laminate surfaces, they\'re built to last decades.',
  },
  {
    q: 'Where are Klovo cabinets made?',
    a: 'Every Klovo cabinet is built in our manufacturing facility in Georgia, USA. Door Kraft, our parent company, has produced over a million cabinets. American-made quality with precision CNC drilling and automated edge-banding.',
  },
  {
    q: 'Can I buy directly from Klovo?',
    a: 'Klovo cabinets will be available through trusted retail partners very soon. Visit our Where to Buy page and sign up to be notified the moment we launch.',
  },
  {
    q: 'What\'s the warranty?',
    a: 'Klovo cabinets come with a 10-year warranty covering defects in materials and workmanship. We stand behind what we build.',
  },
  {
    q: 'Can I disassemble and move the cabinets?',
    a: 'Yes! The same connector system that makes assembly fast also makes disassembly easy. If you move, your Klovo cabinets move with you. Storage that adapts to your life.',
  },
  {
    q: 'What finishes are available?',
    a: 'We currently offer our cabinets in a clean, modern white finish that complements any garage aesthetic. Additional finishes are in development.',
  },
  {
    q: 'How is Klovo different from metal garage cabinets?',
    a: 'Metal cabinets are utilitarian — they look like shop equipment, not home furniture. Klovo cabinets have a premium, furniture-grade finish with scratch-resistant laminate and moisture-proof sealed edgebanding. Push-to-open doors and drawers give a clean, handle-free look. They look like an extension of your home, not an industrial toolbox.',
  },
];
---

<BaseLayout title="FAQ" description="Frequently asked questions about Klovo garage cabinets. Assembly, weight capacity, materials, warranty, and more.">

  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">FAQ</p>
          <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4">Got questions?</h1>
          <p class="text-lg text-klovo-grey">We've got answers. If yours isn't here, <a href="/contact/" class="text-klovo-blue hover:text-klovo-blue-dark underline">reach out</a>.</p>
        </div>

        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <details class="group bg-warm-neutral rounded-lg reveal" style={`transition-delay: ${i * 50}ms`}>
              <summary class="flex items-center justify-between cursor-pointer p-6 text-lg font-semibold text-charcoal hover:text-klovo-blue transition-colors list-none">
                <span>{faq.q}</span>
                <svg class="w-5 h-5 text-klovo-grey flex-shrink-0 ml-4 group-open:rotate-180 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <div class="px-6 pb-6 text-charcoal/70 leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 lg:py-16 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-2xl font-bold text-charcoal mb-4">Still have questions?</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="btn-primary">Contact Us</a>
        <a href="/where-to-buy/" class="btn-secondary">Where to Buy</a>
      </div>
    </div>
  </section>

</BaseLayout>
