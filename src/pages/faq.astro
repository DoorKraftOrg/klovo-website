---
import PageLayout from '../layouts/PageLayout.astro';

const faqs = [
  {
    q: 'What in-store display and merchandising support does Klovo provide?',
    a: 'Klovo provides a tech-enabled in-store display purpose-built for the retail floor. Every retail partner also gets access to the Klovo configurator — a digital tool your sales staff can use with customers to design their garage and land on the right set. It makes the sales conversation faster and helps customers commit with confidence.',
  },
  {
    q: 'How does ordering work?',
    a: "Klovo integrates directly with your EDI system, so purchase orders, inventory updates, and reorders fit into your existing workflow without manual back-and-forth. We're set up to make restocking as frictionless as possible.",
  },
  {
    q: 'Do you offer sales training for our store staff?',
    a: 'Yes. Klovo has localized sales reps across the US who will come to your store in person to train your team on how to sell Klovo — the product story, the GlideLock assembly demo, and how to use the configurator with customers. Ongoing support is available as your staff turns over or new products launch.',
  },
  {
    q: 'What marketing support does Klovo provide to retail partners?',
    a: "Co-op marketing is available. Klovo is active across social media and will provide retail partners with ready-to-use content, lifestyle imagery, and product photos as needed — so your team isn't starting from scratch.",
  },
  {
    q: 'Who is the Klovo customer?',
    a: "Female shoppers, 35–60, focused on family storage and organization. She's the one deciding how the home looks and functions — and she expects the garage to match the rest of it. She's not buying a tool chest; she's buying a room. That buyer profile drives higher average order values and stronger attachment rates than the commodity garage storage customer.",
  },
  {
    q: 'What makes Klovo different from other garage cabinet lines?',
    a: "Three things set Klovo apart at retail. First, the GlideLock assembly system — customers can assemble a full set in under an hour without calling a contractor, which removes the biggest objection in the category. Second, 500 lbs per cabinet with a premium furniture-grade finish, not the utilitarian metal look. Third, 100% Made in USA — that's a real differentiator with today's consumer.",
  },
  {
    q: 'Where are Klovo cabinets made?',
    a: '100% Made in USA. Klovo is built by Door Kraft, a US cabinet manufacturer with over 20 years of experience.',
  },
  {
    q: "What's the warranty, and how are claims handled?",
    a: '1-year limited warranty covering defects in materials and workmanship. Claims go directly to our warranty team at warranty@klovo.com — we respond within 2 business days and handle resolution directly, so your store is not in the middle.',
  },
  {
    q: 'How does Klovo fit into the garage organization category?',
    a: "Garage organization is growing at 2× the rate of overall home improvement. Klovo sits at the premium end of that category — above the commodity wire shelving and metal cabinet lines, but accessible to a much wider buyer than custom built-ins. It fills a gap most retailers don't have a good answer for today.",
  },
];

// FAQPage JSON-LD — qualifies for FAQ rich results in Google SERP
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<PageLayout
  title="Retail Partner FAQ — Carry Klovo"
  description="FAQ for retailers evaluating Klovo — display support, EDI ordering, sales training, co-op marketing, and what makes Klovo the right premium garage cabinet line for your floor."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="page-hero" style="text-align:center;">
    <div class="container">
      <span class="eyebrow">FAQ</span>
      <h1 class="page-h1" style="margin:12px auto 0; max-width:560px;">Questions, <em>answered.</em></h1>
      <p style="font-family:var(--sans); color:var(--muted); font-size:17px; line-height:1.65; margin:16px auto 0; max-width:500px;">
        Everything a buyer needs to know about carrying Klovo. If yours isn't here, <a href="/contact/" style="color:var(--klovo-blue);">reach out</a>.
      </p>
    </div>
  </section>

  <!-- Brand statement + FAQs -->
  <section class="section section--cream">
    <div class="container" style="max-width:800px; margin:0 auto;">

      <!-- Brand statement -->
      <div style="border-left:3px solid var(--amber); padding-left:24px; margin-bottom:56px;">
        <p style="font-family:var(--display); font-size:18px; font-weight:500; color:var(--ink); line-height:1.6; margin:0 0 16px;">
          Most people don't think about storage until their home stops working for them.
        </p>
        <p style="font-family:var(--sans); color:var(--muted); font-size:16px; line-height:1.65; margin:0 0 12px;">
          Once they find the right system — the difference is immediate. They move through their space faster. They can find things. The mental load drops. A home that actually works for you changes how you start your day.
        </p>
        <p style="font-family:var(--sans); color:var(--muted); font-size:16px; line-height:1.65; margin:0;">
          That's what we're building at Klovo. Whole-home storage that reaches people when they're ready — moving in, remodeling, or finally making the call. And doing it is a breeze. From box to done, fast. No friction, no waiting on a contractor.
        </p>
      </div>

      <!-- Accordion -->
      <div style="display:flex; flex-direction:column; gap:8px;">
        {faqs.map((faq) => (
          <details style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
            <summary style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding:20px 24px; list-style:none; gap:16px;">
              <span style="font-family:var(--display); font-weight:600; font-size:17px; color:var(--ink); line-height:1.4;">{faq.q}</span>
              <svg style="flex-shrink:0; color:var(--muted);" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div style="padding:0 24px 20px; font-family:var(--sans); color:var(--muted); font-size:16px; line-height:1.65; border-top:1px solid var(--line);">
              <div style="padding-top:16px;">{faq.a}</div>
            </div>
          </details>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA band -->
  <section class="section section--final">
    <div class="final-inner container" style="text-align:center;">
      <h2 style="font-family:var(--display); font-size:clamp(24px,4vw,34px); font-weight:700; color:var(--cream); margin:0 0 32px;">Ready to explore a partnership?</h2>
      <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
        <a href="/for-retailers/" class="btn btn--primary">Become a Partner &rarr;</a>
        <a href="/contact/" class="btn btn--ghost--dark" style="border-color:var(--cream); color:var(--cream);">Get in Touch</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  details[open] summary svg {
    transform: rotate(180deg);
  }
  details summary svg {
    transition: transform 0.25s ease;
  }
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
