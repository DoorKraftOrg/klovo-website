---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="py-24 lg:py-40 bg-warm-white">
    <div class="section-container text-center">
      <p class="stat-number text-7xl md:text-8xl mb-6">404</p>
      <h1 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">
        This page took a wrong turn.
      </h1>
      <p class="text-lg text-klovo-grey mb-10 max-w-md mx-auto">
        Unlike our cabinets, this page couldn't find its way together. Let's get you back on track.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/cabinets/" class="btn-secondary">Browse Cabinets</a>
      </div>
    </div>
  </section>
</BaseLayout>
