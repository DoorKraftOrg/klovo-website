---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="page-hero" style="text-align:center; min-height:50vh; display:flex; align-items:center;">
    <div class="container">
      <span style="font-family:var(--display); font-size:clamp(80px,12vw,160px); font-weight:800; color:var(--amber); line-height:1; display:block;">404</span>
      <h1 class="page-h1" style="margin:16px auto 0; max-width:480px;">This page is missing.</h1>
      <p style="font-family:var(--sans); color:var(--muted); font-size:17px; margin:16px auto 32px; max-width:400px;">Let's get you back somewhere useful.</p>
      <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn--primary">Back to Home &rarr;</a>
        <a href="/sets/" class="btn btn--ghost--dark">View Sets</a>
      </div>
    </div>
  </section>
</PageLayout>
