---
import PageLayout from '../../layouts/PageLayout.astro';

const title = "Terms of Service";
const description = "Terms of Service for klovo.com. By accessing or using klovo.com and purchasing Klovo products, you agree to be bound by these Terms.";
---

<PageLayout title={title} description={description}>
  <section class="page-hero page-hero--neutral">
    <div class="container" style="max-width:800px;">
      <span class="eyebrow">Legal</span>
      <h1 class="page-h1">{title}</h1>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container" style="max-width:800px;">
      <article class="prose-klovo">

        <p style="font-family:var(--sans); font-size:14px; color:var(--muted);"><em>Last updated: April 2026</em></p>

        <p>By accessing or using klovo.com (the "Site") and purchasing Klovo products, you agree to be bound by these Terms of Service. Please read them carefully.</p>

        <h2>Terms of Service</h2>

        <h3>Products and Orders</h3>
        <p>Klovo reserves the right to refuse or cancel any order at any time. All product descriptions, pricing, and availability are subject to change without notice. Klovo products are intended for personal, residential use.</p>

        <h3>Shipping</h3>
        <p>Klovo ships orders within 5–7 business days from our Georgia, USA facility. Shipping timelines are estimates and may vary. Risk of loss and title for items pass to you upon delivery to the carrier.</p>

        <h3>Returns and Warranty</h3>
        <p>Please refer to our <a href="/pages/shipping-and-returns">Shipping &amp; Returns Policy</a> for complete details on returns and our limited warranty terms.</p>

        <h3>Intellectual Property</h3>
        <p>All content on this Site — including the Klovo name, GlideLock trademark, product designs, and photography — is the property of Klovo and protected by applicable intellectual property laws.</p>

        <h3>Limitation of Liability</h3>
        <p>Klovo's liability to you for any claim arising from your use of our products or Site shall not exceed the purchase price of the product giving rise to the claim.</p>

        <h3>Governing Law</h3>
        <p>These Terms are governed by the laws of the State of Georgia, USA, without regard to its conflict of law principles.</p>

        <h3>Contact</h3>
        <p>Questions? Contact us at klovo.com or through the contact form on our site.</p>

      </article>
    </div>
  </section>
</PageLayout>

<style is:global>
.prose-klovo { font-family: var(--sans); color: var(--ink-soft); font-size: 17px; line-height: 1.75; }
.prose-klovo h2 { font-family: var(--display); font-weight: 700; font-size: clamp(22px,2.8vw,30px); color: var(--ink); margin: 48px 0 16px; }
.prose-klovo h3 { font-family: var(--display); font-weight: 600; font-size: 20px; color: var(--ink); margin: 36px 0 12px; }
.prose-klovo p { margin: 0 0 20px; }
.prose-klovo ul, .prose-klovo ol { padding-left: 24px; margin-bottom: 20px; }
.prose-klovo li { margin-bottom: 8px; }
.prose-klovo strong { color: var(--ink); font-weight: 600; }
.prose-klovo a { color: var(--amber); text-decoration: underline; text-underline-offset: 2px; }
.prose-klovo a:hover { color: var(--ink); }
</style>
