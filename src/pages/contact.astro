---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact Klovo — Garage Cabinet Questions"
  description="Get in touch with the Klovo team. Questions about modular garage cabinets, retail partnerships, or press inquiries."
>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Get in Touch</span>
      <h1 class="page-h1" style="margin:12px 0 0; max-width:520px;">We'd love to hear <em>from you.</em></h1>
      <p style="font-family:var(--sans); color:var(--muted); font-size:17px; line-height:1.65; margin:16px 0 0; max-width:520px;">
        Whether you're a homeowner with questions, a retailer interested in partnerships, or press looking for a story — we're here.
      </p>
    </div>
  </section>

  <!-- Contact content -->
  <section class="section section--cream">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">

        <!-- Left: contact list -->
        <div>
          <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:24px;">

            <li style="display:flex; align-items:baseline; gap:12px;">
              <span style="width:8px; height:8px; border-radius:50%; background:var(--amber); flex-shrink:0; margin-top:6px;"></span>
              <div>
                <p style="font-family:var(--display); font-weight:600; color:var(--ink); font-size:16px; margin:0 0 4px;">Email</p>
                <a href="mailto:hello@klovo.com" style="font-family:var(--sans); color:var(--klovo-blue); font-size:16px;">hello@klovo.com</a>
              </div>
            </li>

            <li style="display:flex; align-items:baseline; gap:12px;">
              <span style="width:8px; height:8px; border-radius:50%; background:var(--amber); flex-shrink:0; margin-top:6px;"></span>
              <div>
                <p style="font-family:var(--display); font-weight:600; color:var(--ink); font-size:16px; margin:0 0 4px;">Retailer inquiries</p>
                <a href="mailto:retailers@klovo.com" style="font-family:var(--sans); color:var(--klovo-blue); font-size:16px;">retailers@klovo.com</a>
              </div>
            </li>

            <li style="display:flex; align-items:baseline; gap:12px;">
              <span style="width:8px; height:8px; border-radius:50%; background:var(--amber); flex-shrink:0; margin-top:6px;"></span>
              <div>
                <p style="font-family:var(--display); font-weight:600; color:var(--ink); font-size:16px; margin:0 0 4px;">Location</p>
                <p style="font-family:var(--sans); color:var(--muted); font-size:16px; line-height:1.65; margin:0;">
                  2 Ravinia Dr, Suite 1600<br />
                  Atlanta, GA 30346<br />
                  United States
                </p>
              </div>
            </li>

            <li style="display:flex; align-items:baseline; gap:12px;">
              <span style="width:8px; height:8px; border-radius:50%; background:var(--amber); flex-shrink:0; margin-top:6px;"></span>
              <div>
                <p style="font-family:var(--display); font-weight:600; color:var(--ink); font-size:16px; margin:0 0 4px;">Social</p>
                <div style="display:flex; gap:12px; flex-wrap:wrap;">
                  <a href="https://www.instagram.com/klovostorage/" target="_blank" rel="noopener noreferrer" style="font-family:var(--sans); color:var(--klovo-blue); font-size:16px;">Instagram</a>
                  <span style="color:var(--line);">&middot;</span>
                  <a href="https://x.com/KlovoStorage" target="_blank" rel="noopener noreferrer" style="font-family:var(--sans); color:var(--klovo-blue); font-size:16px;">X</a>
                  <span style="color:var(--line);">&middot;</span>
                  <a href="https://www.linkedin.com/company/klovo/" target="_blank" rel="noopener noreferrer" style="font-family:var(--sans); color:var(--klovo-blue); font-size:16px;">LinkedIn</a>
                </div>
              </div>
            </li>

          </ul>
        </div>

        <!-- Right: B2B card -->
        <div class="page-card" style="background:var(--neutral); border-radius:12px; padding:36px 32px; border:1px solid var(--line);">
          <span class="eyebrow" style="display:block; margin-bottom:12px;">For Retailers &amp; B2B</span>
          <h2 style="font-family:var(--display); font-size:24px; font-weight:700; color:var(--ink); margin:0 0 12px;">Interested in carrying Klovo?</h2>
          <p style="font-family:var(--sans); color:var(--muted); font-size:16px; line-height:1.65; margin:0 0 24px;">
            We're actively partnering with retailers who want to own the premium garage category. Strong margins, in-store demos, and a buyer profile that drives high AOV.
          </p>
          <a href="/for-retailers/" class="btn btn--primary">Become a Partner &rarr;</a>
        </div>

      </div>
    </div>
  </section>

</PageLayout>

<style>
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
