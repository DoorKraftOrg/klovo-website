---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Where to Buy" description="Klovo premium garage cabinets are coming soon to trusted retailers near you.">

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container text-center">
      <div class="max-w-2xl mx-auto reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
          Coming Soon
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          Klovo is almost here.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          We're finalizing partnerships with trusted retailers to bring Klovo cabinets to you. Sign up below to be the first to know when we launch.
        </p>
      </div>
    </div>
  </section>

  <!-- Coming Soon -->
  <section class="py-16 lg:py-24 bg-warm-neutral">
    <div class="section-container">
      <div class="max-w-2xl mx-auto text-center reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-4">Get notified at launch.</h2>
        <p class="text-klovo-grey mb-8">Drop your email and we'll let you know the moment Klovo cabinets are available to order.</p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
          <input
            type="email"
            name="email"
            placeholder="Your email"
            required
            class="flex-1 px-4 py-3 bg-pure-white border border-warm-neutral rounded text-charcoal placeholder:text-klovo-grey focus:outline-none focus:border-klovo-blue focus:ring-1 focus:ring-klovo-blue transition-colors"
            aria-label="Email address"
          />
          <button type="submit" class="btn-primary">Notify Me</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Become a Retailer -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-4">Want to carry Klovo?</h2>
        <p class="text-lg text-klovo-grey leading-relaxed mb-8">
          We're always looking for retail partners who share our passion for quality and customer experience. Klovo cabinets drive foot traffic, generate social buzz, and deliver strong margins.
        </p>
        <a href="/for-retailers/" class="btn-primary">
          Learn About Partnerships <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-2xl font-bold text-charcoal mb-4">Need help choosing?</h2>
      <p class="text-klovo-grey mb-6 max-w-lg mx-auto">
        Not sure which cabinets are right for your garage? Our team can help you plan the perfect setup.
      </p>
      <a href="/contact/" class="btn-secondary">Contact Us</a>
    </div>
  </section>

</BaseLayout>
