---
import BaseLayout from '../layouts/BaseLayout.astro';
import retailers from '../data/retailers.json';
---

<BaseLayout title="Where to Buy" description="Find Klovo garage cabinets at trusted retailers online. Available on Amazon, Wayfair, and more.">

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container text-center">
      <div class="max-w-2xl mx-auto reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
          Shop Klovo
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          Find Klovo near you.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          Klovo cabinets are available through trusted retail partners. Shop online or find a dealer in your area.
        </p>
      </div>
    </div>
  </section>

  <!-- Online Retailers -->
  <section class="py-16 lg:py-24 bg-warm-neutral">
    <div class="section-container">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-2">Shop Online</h2>
        <p class="text-klovo-grey">Order Klovo cabinets from these trusted retailers.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {retailers.online.map((retailer, i) => (
          <a
            href={retailer.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-pure-white rounded-xl p-8 text-center hover:shadow-lg transition-all duration-300 hover:-translate-y-1 reveal"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="h-12 flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-charcoal group-hover:text-klovo-blue transition-colors lowercase">{retailer.name}</span>
            </div>
            <p class="text-klovo-grey text-sm mb-4">Shop Klovo on {retailer.name}</p>
            <span class="text-klovo-blue font-semibold text-sm inline-flex items-center gap-1">
              Visit Store <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Become a Retailer -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-4">Want to carry Klovo?</h2>
        <p class="text-lg text-klovo-grey leading-relaxed mb-8">
          We're always looking for retail partners who share our passion for quality and customer experience. Klovo cabinets drive foot traffic, generate social buzz, and deliver strong margins.
        </p>
        <a href="/for-retailers/" class="btn-primary">
          Learn About Partnerships <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-2xl font-bold text-charcoal mb-4">Need help choosing?</h2>
      <p class="text-klovo-grey mb-6 max-w-lg mx-auto">
        Not sure which cabinets are right for your garage? Our team can help you plan the perfect setup.
      </p>
      <a href="/contact/" class="btn-secondary">Contact Us</a>
    </div>
  </section>

</BaseLayout>
