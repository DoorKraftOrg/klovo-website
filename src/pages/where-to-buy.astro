---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Where to Buy Klovo Garage Cabinets"
  description="Find Klovo modular garage cabinets at a growing list of retail partners. Looking to carry Klovo in your store? Get in touch about wholesale partnerships."
  keywords="where to buy garage cabinets, Klovo retailers, garage cabinet store, modular garage cabinet retailer"
>

  <!-- Hero -->
  <section class="page-hero" style="text-align:center;">
    <div class="container">
      <span class="eyebrow">Shop Klovo</span>
      <h1 class="page-h1" style="margin:12px auto 0; max-width:560px;">Available at <em>select retailers.</em></h1>
      <p style="font-family:var(--sans); color:var(--muted); font-size:17px; line-height:1.65; margin:16px auto 0; max-width:480px;">
        Find Klovo at a growing list of retail partners. Looking to carry Klovo in your store? Get in touch.
      </p>
    </div>
  </section>

  <!-- Retailers -->
  <section class="section section--neutral">
    <div class="container">
      <div style="text-align:center; margin-bottom:48px;">
        <h2 class="h-section">Retailers</h2>
        <p style="font-family:var(--sans); color:var(--muted); margin:8px 0 0;">Our growing list of retail partners.</p>
      </div>

      <div style="max-width:720px; margin:0 auto;">
        <div style="background:var(--paper); border-radius:12px; padding:48px 40px; text-align:center; border:1px solid var(--line);">
          <p style="font-family:var(--sans); color:var(--muted); font-size:17px; font-style:italic; margin:0;">
            Retailer list coming soon. Reach out if you'd like to be the first to carry Klovo in your area.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="section section--final">
    <div class="final-inner container" style="text-align:center;">
      <h2 style="font-family:var(--display); font-size:clamp(26px,4vw,36px); font-weight:700; color:var(--cream); margin:0 0 16px;">Are you a retailer?</h2>
      <p style="font-family:var(--sans); color:var(--cream); opacity:0.8; font-size:17px; line-height:1.65; margin:0 auto 32px; max-width:520px;">
        Klovo is actively partnering with new retailers. Strong margins, in-store demo moments, and a fast-growing garage category.
      </p>
      <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
        <a href="/for-retailers/" class="btn btn--primary">Become a Partner &rarr;</a>
        <a href="/contact/" class="btn btn--ghost--dark" style="border-color:var(--cream); color:var(--cream);">Get in Touch</a>
      </div>
    </div>
  </section>

</PageLayout>
