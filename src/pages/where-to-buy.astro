---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Where to Buy" description="Find Klovo at a growing list of retail partners. Looking to carry Klovo in your store? Get in touch.">

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container text-center">
      <div class="max-w-2xl mx-auto reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
          Shop Klovo
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          Available at select retailers.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          Find Klovo at a growing list of retail partners. Looking to carry Klovo in your store? Get in touch.
        </p>
      </div>
    </div>
  </section>

  <!-- Retailers -->
  <section class="py-16 lg:py-24 bg-warm-neutral">
    <div class="section-container">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-2">Retailers</h2>
        <p class="text-klovo-grey">Our growing list of retail partners.</p>
      </div>

      <div class="max-w-3xl mx-auto reveal">
        <div class="bg-pure-white rounded-xl p-8 md:p-12 text-center">
          <p class="text-lg text-klovo-grey italic">
            Retailer list coming soon. Reach out if you'd like to be the first to carry Klovo in your area.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- For Retailers CTA -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-4">Are you a retailer?</h2>
        <p class="text-lg text-klovo-grey leading-relaxed mb-8">
          Klovo is actively partnering with new retailers. Strong margins, in-store demo moments, and a fast-growing garage category.
        </p>
        <a href="/for-retailers/" class="btn-primary">
          Become a Partner <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
