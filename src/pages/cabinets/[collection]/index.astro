---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const collections = await getCollection('cabinetCollections');
  const products = await getCollection('products');

  return collections.map(col => ({
    params: { collection: col.data.slug },
    props: {
      collection: col,
      products: products
        .filter(p => p.data.collection === col.data.slug)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { collection, products } = Astro.props;
---

<BaseLayout title={collection.data.title} description={collection.data.description}>

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <nav class="mb-6 text-sm text-klovo-grey" aria-label="Breadcrumb">
        <a href="/cabinets/" class="hover:text-klovo-blue transition-colors">Cabinets</a>
        <span class="mx-2">/</span>
        <span class="text-charcoal">{collection.data.title}</span>
      </nav>

      <div class="max-w-2xl reveal">
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          {collection.data.title}
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          {collection.data.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="py-12 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {products.map((product, i) => (
          <a href={`/cabinets/${collection.data.slug}/${product.id}/`} class="group reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-white">
              <img
                src={product.data.image}
                alt={product.data.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <h3 class="text-lg font-semibold text-charcoal group-hover:text-klovo-blue transition-colors mb-1">
              {product.data.title}
            </h3>
            <p class="text-klovo-grey text-[15px] mb-3">{product.data.description}</p>

            <!-- Quick Specs -->
            <div class="flex items-center gap-4 text-sm">
              <span class="inline-flex items-center gap-1 text-klovo-grey">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                {product.data.specs.width} x {product.data.specs.height}
              </span>
              <span class="inline-flex items-center gap-1 font-semibold text-klovo-blue">
                {product.data.specs.shelfCapacity}/shelf
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 lg:py-16 bg-warm-white">
    <div class="section-container text-center reveal">
      <h2 class="text-2xl font-bold text-charcoal mb-4">Ready to buy?</h2>
      <a href="/where-to-buy/" class="btn-primary">Find a Retailer <span aria-hidden="true">&rarr;</span></a>
    </div>
  </section>

</BaseLayout>
