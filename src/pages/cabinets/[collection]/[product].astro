---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: {
      collection: product.data.collection,
      product: product.id,
    },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const { title, description, image, specs, features, retailers } = product.data;

// Get related products from same collection
const allProducts = await getCollection('products');
const related = allProducts
  .filter(p => p.data.collection === product.data.collection && p.id !== product.id)
  .slice(0, 3);
---

<BaseLayout title={title} description={description}>

  <section class="py-12 lg:py-20 bg-warm-white">
    <div class="section-container">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-klovo-grey" aria-label="Breadcrumb">
        <a href="/cabinets/" class="hover:text-klovo-blue transition-colors">Cabinets</a>
        <span class="mx-2">/</span>
        <a href={`/cabinets/${product.data.collection}/`} class="hover:text-klovo-blue transition-colors capitalize">{product.data.collection}</a>
        <span class="mx-2">/</span>
        <span class="text-charcoal">{title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Image -->
        <div class="reveal">
          <div class="rounded-lg overflow-hidden bg-warm-neutral aspect-[4/3]">
            <img
              src={image}
              alt={title}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>

        <!-- Details -->
        <div class="reveal reveal-delay-1">
          <h1 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">{title}</h1>
          <p class="text-lg text-charcoal/70 leading-relaxed mb-8">{description}</p>

          <!-- Key Stats -->
          <div class="grid grid-cols-3 gap-4 mb-8 p-6 bg-warm-neutral rounded-lg">
            <div class="text-center">
              <p class="stat-number text-2xl md:text-3xl mb-1">{specs.shelfCapacity}</p>
              <p class="text-xs text-klovo-grey uppercase tracking-wider">per shelf</p>
            </div>
            <div class="text-center border-x border-charcoal/10">
              <p class="stat-number text-2xl md:text-3xl mb-1">&lt;2</p>
              <p class="text-xs text-klovo-grey uppercase tracking-wider">min build</p>
            </div>
            <div class="text-center">
              <p class="stat-number text-2xl md:text-3xl mb-1">0</p>
              <p class="text-xs text-klovo-grey uppercase tracking-wider">tools</p>
            </div>
          </div>

          <!-- Where to Buy -->
          {retailers && retailers.length > 0 && (
            <div class="mb-8">
              <h3 class="text-sm font-semibold text-charcoal uppercase tracking-wider mb-3">Where to Buy This Cabinet</h3>
              <div class="flex flex-wrap gap-3">
                {retailers.map(r => (
                  <a
                    href={r.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-primary !py-3"
                  >
                    Buy on {r.name} <span aria-hidden="true">&rarr;</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Features -->
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-charcoal uppercase tracking-wider mb-3">Features</h3>
            <ul class="space-y-2">
              {features.map(f => (
                <li class="flex items-start gap-2 text-[15px] text-charcoal/80">
                  <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Specifications Table -->
      <div class="mt-16 reveal">
        <h2 class="text-2xl font-bold text-charcoal mb-6">Specifications</h2>
        <div class="bg-warm-neutral rounded-lg overflow-hidden overflow-x-auto">
          <table class="w-full text-left min-w-[400px]">
            <tbody>
              <tr class="border-b border-charcoal/10">
                <td class="py-4 px-6 font-medium text-charcoal">Width</td>
                <td class="py-4 px-6 text-charcoal/70">{specs.width}</td>
              </tr>
              <tr class="border-b border-charcoal/10">
                <td class="py-4 px-6 font-medium text-charcoal">Height</td>
                <td class="py-4 px-6 text-charcoal/70">{specs.height}</td>
              </tr>
              <tr class="border-b border-charcoal/10">
                <td class="py-4 px-6 font-medium text-charcoal">Depth</td>
                <td class="py-4 px-6 text-charcoal/70">{specs.depth}</td>
              </tr>
              <tr class="border-b border-charcoal/10">
                <td class="py-4 px-6 font-medium text-charcoal">Weight</td>
                <td class="py-4 px-6 text-charcoal/70">{specs.weight}</td>
              </tr>
              <tr class="border-b border-charcoal/10">
                <td class="py-4 px-6 font-medium text-charcoal">Shelf Capacity</td>
                <td class="py-4 px-6 text-charcoal/70">{specs.shelfCapacity}</td>
              </tr>
              <tr class="border-b border-charcoal/10">
                <td class="py-4 px-6 font-medium text-charcoal">Material</td>
                <td class="py-4 px-6 text-charcoal/70">{specs.material}</td>
              </tr>
              {specs.shelves && (
                <tr class="border-b border-charcoal/10">
                  <td class="py-4 px-6 font-medium text-charcoal">Adjustable Shelves</td>
                  <td class="py-4 px-6 text-charcoal/70">{specs.shelves}</td>
                </tr>
              )}
              {specs.drawers && (
                <tr>
                  <td class="py-4 px-6 font-medium text-charcoal">Drawers</td>
                  <td class="py-4 px-6 text-charcoal/70">{specs.drawers}</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Product Description -->
      <div class="mt-12 max-w-3xl reveal">
        <div class="prose prose-lg text-charcoal/80">
          <Content />
        </div>
      </div>

      <!-- Related Products -->
      {related.length > 0 && (
        <div class="mt-20 reveal">
          <h2 class="text-2xl font-bold text-charcoal mb-8">Goes Great With</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {related.map(r => (
              <a href={`/cabinets/${r.data.collection}/${r.id}/`} class="group">
                <div class="img-zoom-container rounded-lg mb-3 aspect-[4/3] bg-warm-neutral">
                  <img src={r.data.image} alt={r.data.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <h3 class="font-semibold text-charcoal group-hover:text-klovo-blue transition-colors">{r.data.title}</h3>
                <p class="text-sm text-klovo-grey">{r.data.specs.shelfCapacity}/shelf</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
