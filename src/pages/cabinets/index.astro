---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const cabinetCollections = await getCollection('cabinetCollections');

// Group products by collection
const collectionGroups = cabinetCollections
  .sort((a, b) => a.data.order - b.data.order)
  .map(col => ({
    ...col.data,
    products: allProducts
      .filter(p => p.data.collection === col.data.slug)
      .sort((a, b) => a.data.order - b.data.order),
  }));
---

<BaseLayout title="Cabinets" description="Explore Klovo's premium garage cabinet collection. Tall, base, and wall cabinets. 500 lbs per cabinet, scratch-resistant, moisture-proof.">

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-2xl reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-3">
          The Collection
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          Storage that looks like furniture.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          Assemble a full set in under an hour. Scratch-resistant laminate, moisture-proof sealed edgebanding, 500 lbs per cabinet, and push-to-open hardware — no handles needed.
        </p>
      </div>
    </div>
  </section>

  <!-- Collections -->
  {collectionGroups.map((col, i) => (
    <section class={`py-16 lg:py-24 ${i % 2 === 0 ? 'bg-warm-neutral' : 'bg-warm-white'}`}>
      <div class="section-container">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 reveal">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-2">{col.title}</h2>
            <p class="text-lg text-klovo-grey max-w-xl">{col.description}</p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {col.products.map((product, j) => (
            <a href={`/cabinets/${col.slug}/${product.id}/`} class="group reveal" style={`transition-delay: ${j * 100}ms`}>
              <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-white">
                <img
                  src={product.data.image}
                  alt={product.data.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <h3 class="text-lg font-semibold text-charcoal group-hover:text-klovo-blue transition-colors mb-1">
                {product.data.title}
              </h3>
              <p class="text-klovo-grey text-[15px] mb-2">{product.data.description}</p>
              <div class="flex items-center gap-4 text-sm text-klovo-grey">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                  {product.data.specs.width} W
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg>
                  {product.data.specs.shelfCapacity}/shelf
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-4">Ready to transform your garage?</h2>
      <p class="text-lg text-klovo-grey mb-8 max-w-lg mx-auto">Find Klovo at a retailer near you.</p>
      <a href="/where-to-buy/" class="btn-primary">Where to Buy <span aria-hidden="true">&rarr;</span></a>
    </div>
  </section>

</BaseLayout>
