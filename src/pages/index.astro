---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Cabinet sets for the modern garage. Pre-designed systems, sized for your wall. Assemble a full set in under an hour. 500 lbs per cabinet. 100% Made in USA.">

  <!-- ============================================
       SECTION 1: HERO
       ============================================ -->
  <section class="relative min-h-[85vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/scenes/klovo-bright-garage.png"
        alt="Klovo garage cabinet set in a bright modern garage with bike and stairs"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal/90 via-charcoal/70 to-charcoal/30 md:to-transparent"></div>
    </div>

    <div class="section-container relative z-10 py-24 lg:py-32">
      <div class="max-w-2xl">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4 reveal">
          Premium garage cabinets
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-[56px] font-bold text-pure-white leading-[1.1] mb-6 reveal reveal-delay-1">
          Cabinet sets for the modern garage.
        </h1>
        <p class="text-lg md:text-xl text-pure-white/80 leading-relaxed mb-10 max-w-lg reveal reveal-delay-2">
          Pre-designed systems, sized for your wall. Assemble a full set in under an hour. Load capacity of 500 lbs per cabinet. 100% Made in USA.
        </p>
        <div class="flex flex-wrap gap-4 reveal reveal-delay-3">
          <a href="/sets/" class="btn-amber">
            See our Preset Collection <span aria-hidden="true">&rarr;</span>
          </a>
          <a href="/where-to-buy/" class="btn-secondary !border-pure-white !text-pure-white hover:!bg-pure-white hover:!text-charcoal">
            Where to Buy
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.5">
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </div>
  </section>

  <!-- ============================================
       SECTION 2: THE COLLECTION (WIDTH CARDS)
       ============================================ -->
  <section class="py-20 lg:py-28 bg-warm-white">
    <div class="section-container">
      <div class="text-center mb-16 reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
          The Collection
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4 leading-tight">
          Pre-designed systems from 2 feet to 16 feet.<br/>Sized for your wall.
        </h2>
        <p class="text-lg text-klovo-grey max-w-2xl mx-auto">
          Whatever your garage is — a home office, family hub, children's playroom, workshop, or home gym — there's a Klovo set that fits.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <!-- 4 feet -->
        <a href="/sets/#width-4ft" class="group reveal reveal-delay-1">
          <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-neutral">
            <img
              src="/images/products/tall-cabinet-solo.png"
              alt="4 ft Klovo set — tall cabinet in a compact garage corner"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="text-xl font-semibold text-charcoal group-hover:text-klovo-blue transition-colors mb-1">
            4 feet
          </h3>
          <p class="text-klovo-grey text-[15px] mb-3">
            A starter set for compact spaces. Perfect for a children's playroom corner, a mudroom drop zone, or a home gym accessory wall.
          </p>
          <span class="text-klovo-blue font-semibold text-sm inline-flex items-center gap-1">
            Shop 4 ft sets <span aria-hidden="true">&rarr;</span>
          </span>
        </a>

        <!-- 8 feet -->
        <a href="/sets/#width-8ft" class="group reveal reveal-delay-2">
          <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-neutral">
            <img
              src="/images/sets/set-08-hero.jpg"
              alt="8 ft Klovo set as a full wall of storage"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="text-xl font-semibold text-charcoal group-hover:text-klovo-blue transition-colors mb-1">
            8 feet
          </h3>
          <p class="text-klovo-grey text-[15px] mb-3">
            A full wall. Big enough for a home office, a dedicated workshop, or most of a home gym.
          </p>
          <span class="text-klovo-blue font-semibold text-sm inline-flex items-center gap-1">
            Shop 8 ft sets <span aria-hidden="true">&rarr;</span>
          </span>
        </a>

        <!-- 16 feet -->
        <a href="/sets/#width-16ft" class="group reveal reveal-delay-3">
          <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-neutral">
            <img
              src="/images/sets/set-16-hero.jpg"
              alt="16 ft Klovo set spanning a two-car garage wall"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="text-xl font-semibold text-charcoal group-hover:text-klovo-blue transition-colors mb-1">
            16 feet
          </h3>
          <p class="text-klovo-grey text-[15px] mb-3">
            The maximum setup. A complete family hub, full workshop with worktop, or a pro-level home gym.
          </p>
          <span class="text-klovo-blue font-semibold text-sm inline-flex items-center gap-1">
            Shop 16 ft sets <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      </div>

      <div class="text-center mt-12 reveal">
        <a href="/sets/" class="btn-primary">
          View All Sets <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 3: FAST ASSEMBLY
       ============================================ -->
  <section class="py-20 lg:py-28 bg-warm-neutral">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <button
            type="button"
            class="group relative w-full rounded-lg overflow-hidden aspect-video bg-charcoal shadow-xl cursor-pointer"
            data-video-open
            aria-label="Play assembly video"
          >
            <img
              src="/images/assembly/hands-pressing.png"
              alt="Klovo cabinet assembly — panels pushing together"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="w-20 h-20 bg-klovo-blue/90 group-hover:bg-klovo-blue rounded-full flex items-center justify-center transition-all duration-300 group-hover:scale-110 shadow-lg">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                  <polygon points="8,5 19,12 8,19" />
                </svg>
              </span>
            </span>
          </button>
        </div>

        <div class="reveal reveal-delay-1">
          <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
            Video / Fast Assembly
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-6 leading-tight">
            Flat box to fully assembled<br/>in under 3 minutes a cabinet.
          </h2>
          <p class="text-lg text-charcoal/70 leading-relaxed mb-8">
            Panels lock together with a simple push — no drills, no cam locks, no Allen wrenches. A full set in less than 1 hour. The only tool you'll need: a screwdriver to secure the back panel.
          </p>

          <div class="grid grid-cols-3 gap-4 mb-8">
            <div>
              <p class="stat-number text-3xl md:text-4xl mb-1">3 min</p>
              <p class="text-xs text-klovo-grey font-medium uppercase tracking-wider">per cabinet</p>
            </div>
            <div>
              <p class="stat-number text-3xl md:text-4xl mb-1">&lt;1 hr</p>
              <p class="text-xs text-klovo-grey font-medium uppercase tracking-wider">full set</p>
            </div>
            <div>
              <p class="stat-number text-3xl md:text-4xl mb-1">500</p>
              <p class="text-xs text-klovo-grey font-medium uppercase tracking-wider">lbs / cabinet</p>
            </div>
          </div>

          <a href="/assembly/" class="btn-primary">
            See How It Works <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 4: WHY KLOVO
       ============================================ -->
  <section class="py-20 lg:py-28 bg-warm-white">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <div class="rounded-lg overflow-hidden shadow-xl aspect-square">
            <img
              src="/images/scenes/base-wall-pegboard.png"
              alt="Klovo base cabinets with pegboard workspace — built for garage conditions"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="reveal reveal-delay-1">
          <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
            Why Klovo
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-6 leading-tight">
            Built for garages. Not kitchens.
          </h2>
          <p class="text-lg text-charcoal/70 leading-relaxed mb-8">
            Klovo is engineered for garage conditions from the first panel up.
          </p>

          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-charcoal">18-inch depth — built for garages, not kitchens</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-charcoal">Sealed with 1mm PVC edgebanding on all exposed edges — moisture-resistant</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-charcoal">Scratch-resistant laminate — takes extreme daily use, not dents</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-charcoal">Push-to-open drawers and doors — no handles that take up space</span>
            </li>
          </ul>

          <div class="mt-8">
            <a href="/specs/" class="btn-primary">
              See All Specs <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 5: STATS BAR
       ============================================ -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">
          Built for the way garages are actually used.
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 text-center">
        <div class="reveal">
          <p class="stat-number text-3xl md:text-4xl lg:text-5xl mb-2">&lt;1%</p>
          <p class="text-sm text-charcoal leading-snug">of garages already finished</p>
        </div>
        <div class="reveal reveal-delay-1">
          <p class="stat-number text-3xl md:text-4xl lg:text-5xl mb-2">68%</p>
          <p class="text-sm text-charcoal leading-snug">of urban homeowners say they don't have enough storage</p>
        </div>
        <div class="reveal reveal-delay-2">
          <p class="stat-number text-3xl md:text-4xl lg:text-5xl mb-2">78M</p>
          <p class="text-sm text-charcoal leading-snug">Americans with home fitness equipment</p>
        </div>
        <div class="reveal reveal-delay-3">
          <p class="stat-number text-3xl md:text-4xl lg:text-5xl mb-2">55%</p>
          <p class="text-sm text-charcoal leading-snug">of Americans work on garage projects weekly</p>
        </div>
      </div>

      <p class="text-center text-xs text-klovo-grey mt-10 reveal">
        Sources: Houzz, Fortune Business Insights, Grand View Research, Mordor Intelligence
      </p>
    </div>
  </section>

  <!-- ============================================
       SECTION 6: REAL GARAGES
       ============================================ -->
  <section class="py-20 lg:py-28 bg-warm-white">
    <div class="section-container">
      <div class="text-center mb-12 reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-3">
          Real Garages
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal">
          See what's possible.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
        <div class="reveal reveal-delay-1">
          <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-neutral">
            <img
              src="/images/scenes/workspace-track-lights.png"
              alt="Klovo workspace with track lighting, organized tools, and pegboard"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <p class="text-charcoal text-[15px]">
            The full Klovo system — Sports gear, toys, gym accessories, tools, everything in its place
          </p>
        </div>

        <div class="reveal reveal-delay-2">
          <div class="img-zoom-container rounded-lg mb-4 aspect-[4/3] bg-warm-neutral">
            <img
              src="/images/scenes/workspace-pegboard.png"
              alt="Klovo garage workspace with pegboard, drill, and organized storage"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <p class="text-charcoal text-[15px]">
            A garage the whole family can enjoy
          </p>
        </div>
      </div>

      <div class="text-center mt-12 reveal">
        <a href="/gallery/" class="btn-secondary">
          See the Gallery <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 7: SHOP KLOVO (RETAILERS)
       ============================================ -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
        Shop Klovo
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">
        Available at select retailers.
      </h2>
      <p class="text-lg text-klovo-grey mb-8 max-w-xl mx-auto">
        Find Klovo at a growing list of retail partners.
      </p>
      <a href="/where-to-buy/" class="btn-primary">
        Find a Retailer <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- ============================================
       SECTION 8: FINAL CTA
       ============================================ -->
  <section class="py-20 lg:py-28 bg-warm-white">
    <div class="section-container text-center reveal">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal mb-6 leading-tight">
        Find the set that fits your garage.
      </h2>
      <p class="text-lg text-klovo-grey max-w-xl mx-auto mb-10">
        15+ pre-designed sets. One for how you actually use the space.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/sets/" class="btn-amber">
          View Sets <span aria-hidden="true">&rarr;</span>
        </a>
        <a href="/sets/" class="btn-secondary">
          Find Your Set
        </a>
      </div>
    </div>
  </section>

  <!-- Video Modal (Vimeo) -->
  <div
    id="video-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-charcoal/90 backdrop-blur-sm p-4"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Assembly video"
  >
    <div class="relative w-full max-w-[min(90vw,45vh)] mx-auto">
      <button
        type="button"
        class="absolute -top-12 right-0 text-white hover:text-klovo-amber transition-colors"
        data-video-close
        aria-label="Close video"
      >
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
      <div class="relative bg-black rounded-lg overflow-hidden shadow-2xl" style="aspect-ratio: 9 / 16;">
        <div id="video-iframe-container" class="absolute inset-0"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const modal = document.getElementById('video-modal');
      const container = document.getElementById('video-iframe-container');
      const openBtns = document.querySelectorAll('[data-video-open]');
      const closeBtns = document.querySelectorAll('[data-video-close]');
      const vimeoSrc = 'https://player.vimeo.com/video/1131081541?autoplay=1&title=0&byline=0&portrait=0&badge=0&autopause=0&player_id=0&app_id=58479';

      function open() {
        if (!modal || !container) return;
        container.innerHTML = '<iframe src="' + vimeoSrc + '" class="w-full h-full" frameborder="0" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" referrerpolicy="strict-origin-when-cross-origin" title="Modular Garage Cabinet System — 500 lb Strength, Quick Install"></iframe>';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function close() {
        if (!modal || !container) return;
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.setAttribute('aria-hidden', 'true');
        container.innerHTML = '';
        document.body.style.overflow = '';
      }

      openBtns.forEach(function (b) { b.addEventListener('click', open); });
      closeBtns.forEach(function (b) { b.addEventListener('click', close); });
      modal && modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) close();
      });
    })();
  </script>

</BaseLayout>
