---
import HomeLayout from '../layouts/HomeLayout.astro';
---

<HomeLayout
  title="Klovo | Cabinet sets for the modern garage"
  description="Modular garage cabinet sets from 2 to 16 ft. DIY GlideLock assembly in under an hour. 500 lbs per cabinet, push-to-open, engineered wood. 100% Made in USA."
  keywords="modular garage cabinets, garage cabinet sets, DIY garage cabinet kit, RTA garage cabinet, push-to-open garage cabinets, soft-close garage cabinets, engineered wood garage cabinets, garage organization set, garage shelving system, garage storage cabinets, GlideLock, made in USA garage cabinets"
>

  <!-- NAV -->
  <nav class="nav" id="site-nav">
    <a href="/" class="nav-logo" aria-label="Klovo home">
      <img src="/images/klovo-logo-official.png" alt="Klovo" />
    </a>
    <div class="nav-links" id="nav-links">
      <a href="/sets/">Sets</a>
      <a href="/assembly/">Assembly</a>
      <a href="/specs/">Specs</a>
      <a href="/gallery/">Gallery</a>
      <a href="/about/">About</a>
      <a href="/for-retailers/">For Retailers</a>
    </div>
    <a href="/where-to-buy/" class="nav-cta">Where to Buy</a>
    <button class="nav-burger" id="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
      <i></i><i></i><i></i>
    </button>
  </nav>

  <main id="main-content">

    <!-- SECTION 1 — HERO -->
    <section class="hero">
      <div class="hero-photo">
        <img src="/images/scenes/klovo-bright-garage.png" alt="A modern garage with Klovo cabinets" loading="eager" />
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-inner">
        <div class="hero-content">
          <span class="eyebrow eyebrow--light">Premium Garage Cabinets</span>
          <h1 class="h-display">
            Cabinet sets for the<br/><em>modern garage.</em>
          </h1>
          <p class="hero-sub">
            Pre-designed systems, sized for your wall. Assemble a full set in under an hour. Load capacity of 500 lbs per cabinet. 100% Made in USA.
          </p>
          <div class="hero-price">
            <span class="hero-price-label">Sets from</span>
            <span class="hero-price-val"><em>$589</em></span>
            <span class="hero-price-note">single locker · full walls to $5,008</span>
          </div>
          <div class="hero-ctas">
            <a href="/sets/" class="btn btn--primary">See our sets &rarr;</a>
            <a href="/where-to-buy/" class="btn btn--ghost">Where to buy</a>
          </div>
        </div>
      </div>
      <div class="hero-scroll" aria-hidden="true">
        <span class="hero-scroll-line"></span>
        <span class="hero-scroll-text">Scroll</span>
      </div>
    </section>

    <!-- SECTION 2 — THE COLLECTION -->
    <section class="section section--cream">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">The Collection</span>
          <h2 class="h-section">
            Pre-designed systems from 2 feet to&nbsp;16&nbsp;feet.<br/>
            <em>Sized for your wall.</em>
          </h2>
          <p class="section-lede">
            Whatever purpose your garage serves — home office, family hub, children's playroom, workshop, or home gym — there's a Klovo set that fits.
          </p>
        </div>

        <div class="collection-grid">
          <a href="/sets/#width-2ft" class="collection-card">
            <div class="collection-card-img collection-card-img--small">
              <img src="/images/products/tall-cabinet-solo.png" alt="2 ft. Klovo set" loading="lazy" />
            </div>
            <div class="collection-card-body">
              <span class="collection-card-tag">2 feet</span>
              <p class="collection-card-desc">
                The smallest set. A single tall cabinet — perfect for a corner, mudroom drop zone, or standalone utility locker.
              </p>
              <span class="collection-card-link">Shop 2 ft sets &rarr;</span>
            </div>
          </a>

          <a href="/sets/#width-8ft" class="collection-card">
            <div class="collection-card-img">
              <img src="/images/sets/set-08-hero.jpg" alt="8 ft. Klovo set" loading="lazy" />
            </div>
            <div class="collection-card-body">
              <span class="collection-card-tag">8 feet</span>
              <p class="collection-card-desc">
                A full wall. Big enough for a home office, a dedicated workshop, or most of a home gym.
              </p>
              <span class="collection-card-link">Shop 8 ft sets &rarr;</span>
            </div>
          </a>

          <a href="/sets/#width-16ft" class="collection-card">
            <div class="collection-card-img">
              <img src="/images/sets/set-16-hero.jpg" alt="16 ft. Klovo set" loading="lazy" />
            </div>
            <div class="collection-card-body">
              <span class="collection-card-tag">16 feet</span>
              <p class="collection-card-desc">
                The maximum setup. A complete family hub, full workshop with worktop, or a pro-level home gym.
              </p>
              <span class="collection-card-link">Shop 16 ft sets &rarr;</span>
            </div>
          </a>
        </div>

        <div class="section-cta">
          <a href="/sets/" class="btn btn--primary">View all sets &rarr;</a>
        </div>
      </div>
    </section>

    <!-- SECTION 3 — FAST ASSEMBLY -->
    <section class="section section--neutral">
      <div class="container">
        <div class="split split--video-left">
          <div class="split-media">
            <div class="video-card">
              <img src="/images/assembly/hands-pressing.png" alt="Hands pressing Klovo cabinet panels together" loading="lazy" />
              <button class="video-play" data-video-open aria-label="Play assembly video">
                <svg viewBox="0 0 32 36" width="22" height="26" aria-hidden="true">
                  <path d="M0 0 L32 18 L0 36 Z" fill="#0A2A52"/>
                </svg>
              </button>
              <div class="video-badge">
                <span class="video-badge-dot"></span>
                Watch &middot; 0:41
              </div>
            </div>
          </div>
          <div class="split-text">
            <span class="eyebrow">Fast Assembly</span>
            <h2 class="h-section">
              Flat box to fully assembled in under <em>3 minutes</em> a cabinet.
            </h2>
            <p class="split-body">
              Panels lock together with a simple push — no drills, no cam locks, no Allen wrenches. A full set in less than 1 hour.
            </p>
            <div class="stats-row">
              <div class="stat">
                <div class="stat-val">3 min</div>
                <div class="stat-label">per cabinet</div>
              </div>
              <span class="stat-sep" aria-hidden="true"></span>
              <div class="stat">
                <div class="stat-val">Less than 1 hr</div>
                <div class="stat-label">full set</div>
              </div>
              <span class="stat-sep" aria-hidden="true"></span>
              <div class="stat">
                <div class="stat-val">500 lbs</div>
                <div class="stat-label">load capacity, per cabinet</div>
              </div>
            </div>
            <a href="/assembly/" class="btn btn--primary">See how it works &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 4 — WHY KLOVO -->
    <section class="section section--cream">
      <div class="container">
        <div class="split">
          <div class="split-media">
            <div class="why-photo">
              <img src="/images/scenes/base-wall-pegboard.png" alt="Klovo base cabinets with pegboard workspace" loading="lazy" />
              <div class="why-photo-corner">
                <span>Made for</span>
                <strong>real garages.</strong>
              </div>
            </div>
          </div>
          <div class="split-text">
            <span class="eyebrow">Why Klovo</span>
            <h2 class="h-section">
              Built for garages.<br/><em>Not kitchens.</em>
            </h2>
            <p class="split-body">
              Klovo is engineered for garage conditions from the first panel up.
            </p>
            <ul class="check-list">
              <li>
                <span class="check-mark" aria-hidden="true">&#10003;</span>
                <span><strong>18-inch depth</strong> — built for garages, not kitchens</span>
              </li>
              <li>
                <span class="check-mark" aria-hidden="true">&#10003;</span>
                <span><strong>Sealed with 1mm PVC edgebanding</strong> on all exposed edges — moisture-resistant</span>
              </li>
              <li>
                <span class="check-mark" aria-hidden="true">&#10003;</span>
                <span><strong>Scratch-resistant laminate</strong> — takes extreme daily use, not dents</span>
              </li>
              <li>
                <span class="check-mark" aria-hidden="true">&#10003;</span>
                <span><strong>Push-to-open drawers and doors</strong> — no handles that take up space</span>
              </li>
            </ul>
            <a href="/specs/" class="btn btn--primary">See all specs &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 5 — STATS BAR -->
    <section class="section section--stats">
      <div class="container">
        <h2 class="h-section h-section--center">
          Built for the way garages are <em>actually</em> used.
        </h2>
        <div class="big-stats">
          <div class="big-stat">
            <div class="big-stat-val">Less than 1%</div>
            <div class="big-stat-label">of US garages have finished storage</div>
          </div>
          <div class="big-stat">
            <div class="big-stat-val">68%</div>
            <div class="big-stat-label">of urban homeowners say they don't have enough storage</div>
          </div>
          <div class="big-stat">
            <div class="big-stat-val">78M</div>
            <div class="big-stat-label">Americans with home fitness equipment</div>
          </div>
          <div class="big-stat">
            <div class="big-stat-val">55%</div>
            <div class="big-stat-label">of Americans work on garage projects weekly</div>
          </div>
        </div>
        <p class="stats-source">Source: Houzz, Fortune Business Insights, Statista, NAHB</p>
      </div>
    </section>

    <!-- SECTION 6 — REAL GARAGES -->
    <section class="section section--cream">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Real Garages</span>
          <h2 class="h-section">See what's possible.</h2>
        </div>
        <div class="gallery-grid">
          <figure class="gallery-card">
            <div class="gallery-img">
              <img src="/images/scenes/workspace-pegboard.png" alt="Organized garage with pegboard, drill" loading="lazy" />
            </div>
            <figcaption class="gallery-cap">
              <span class="gallery-cap-line"></span>
              The full Klovo system — sports gear, toys, gym accessories, tools, everything in its place
            </figcaption>
          </figure>
          <figure class="gallery-card">
            <div class="gallery-img">
              <img src="/images/scenes/workspace-track-lights.png" alt="Garage with track lighting" loading="lazy" />
            </div>
            <figcaption class="gallery-cap">
              <span class="gallery-cap-line"></span>
              A garage the whole family can enjoy
            </figcaption>
          </figure>
        </div>
        <div class="section-cta">
          <a href="/gallery/" class="btn btn--ghost btn--ghost--dark">See the gallery &rarr;</a>
        </div>
      </div>
    </section>

    <!-- SECTION 6.5 — FROM THE WORKSHOP -->
    <section class="section section--paper journal">
      <div class="container">
        <div class="journal-head">
          <div>
            <span class="eyebrow">From the Workshop</span>
            <h2 class="h-section">Garage knowledge,<br/><em>straight from us.</em></h2>
          </div>
          <a href="/blogs/news/" class="journal-head-link">All articles &rarr;</a>
        </div>
        <div class="journal-grid">
          <a href="/blogs/news/how-to-choose-a-garage-cabinet-that-actually-lasts" class="journal-card">
            <div class="journal-card-meta">
              <span>Buyer's Guide</span>
              <span class="journal-card-meta-dot"></span>
              <span>8 min read</span>
            </div>
            <h3 class="journal-card-title">How to choose a garage cabinet that <em>actually</em> lasts.</h3>
            <p class="journal-card-blurb">Plywood vs. particleboard, edge banding, hinge cycles — what to ask before you buy.</p>
            <span class="journal-card-link">Read the guide &rarr;</span>
          </a>
          <a href="/blogs/news/klovo-vs-steel-cabinet-brands" class="journal-card">
            <div class="journal-card-meta">
              <span>Comparison</span>
              <span class="journal-card-meta-dot"></span>
              <span>6 min read</span>
            </div>
            <h3 class="journal-card-title">Klovo vs. the steel cabinet brands you already <em>know.</em></h3>
            <p class="journal-card-blurb">Honest side-by-side: weight capacity, depth, finish, assembly, and what the price actually gets you.</p>
            <span class="journal-card-link">See the comparison &rarr;</span>
          </a>
          <a href="/blogs/news/setting-up-a-family-friendly-garage-in-one-weekend" class="journal-card">
            <div class="journal-card-meta">
              <span>Setup</span>
              <span class="journal-card-meta-dot"></span>
              <span>5 min read</span>
            </div>
            <h3 class="journal-card-title">Setting up a family-friendly garage in <em>one weekend.</em></h3>
            <p class="journal-card-blurb">Drop zones, kid-safe heights, sports-gear storage — a real plan for a real Saturday.</p>
            <span class="journal-card-link">Read the post &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- SECTION 7 — SHOP KLOVO (Retailer CTA) -->
    <section class="section section--neutral retailer-band">
      <div class="container retailer-inner">
        <span class="eyebrow">Shop Klovo</span>
        <h2 class="h-section h-section--center">
          Available at <em>select retailers.</em>
        </h2>
        <p class="retailer-body">Find Klovo at a growing list of retail partners.</p>
        <a href="/where-to-buy/" class="btn btn--primary">Find a retailer &rarr;</a>
      </div>
    </section>

    <!-- SECTION 8 — FINAL CTA -->
    <section class="section section--final">
      <div class="container final-inner">
        <h2 class="h-final">
          Find the set that fits<br/><em>your garage.</em>
        </h2>
        <p class="final-body">15+ pre-designed sets. One for how you actually use the space.</p>
        <div class="final-ctas">
          <a href="/sets/" class="btn btn--primary">View sets &rarr;</a>
          <a href="/sets/" class="btn btn--ghost btn--ghost--dark">Find your set</a>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <img src="/images/klovo-logo-official.png" alt="Klovo" class="footer-logo" />
          <p class="footer-tag">Cabinet sets for the modern garage. <br/>Made in the USA — factory in Georgia.</p>
        </div>
        <div class="footer-cols">
          <div>
            <div class="footer-h">Shop</div>
            <a href="/sets/">All Sets</a>
            <a href="/assembly/">Assembly</a>
            <a href="/specs/">Specs</a>
            <a href="/gallery/">Gallery</a>
            <a href="/where-to-buy/">Where to Buy</a>
          </div>
          <div>
            <div class="footer-h">Company</div>
            <a href="/about/">About</a>
            <a href="/for-retailers/">For Retailers</a>
            <a href="/blogs/news/">Blog</a>
            <a href="/contact/">Contact</a>
            <a href="/faq/">FAQ</a>
          </div>
          <div>
            <div class="footer-h">Support</div>
            <a href="/warranty/">Warranty</a>
            <a href="/contact/">Help</a>
          </div>
          <div class="footer-news">
            <div class="footer-h">Stay in the loop</div>
            <p class="footer-news-tag">Garage tips, new sets, the occasional dad joke.</p>
            <form class="footer-news-form" onsubmit="event.preventDefault();">
              <input type="email" placeholder="your email" aria-label="email" />
              <button type="submit">Join</button>
            </form>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 Klovo Storage by Door Kraft. All rights reserved.</span>
        <span class="footer-bottom-links">
          <a href="/warranty/">Warranty</a> &middot; <a href="/pages/privacy-policy/">Privacy</a> &middot; <a href="/pages/terms-of-service/">Terms</a>
        </span>
      </div>
    </div>
  </footer>

  <!-- Video Modal (Vimeo — portrait 9:16) -->
  <div
    id="video-modal"
    style="display:none; position:fixed; inset:0; z-index:200; align-items:center; justify-content:center; background:rgba(15,10,4,0.92); backdrop-filter:blur(4px); padding:1rem;"
    role="dialog"
    aria-modal="true"
    aria-label="Assembly video"
    aria-hidden="true"
  >
    <div style="position:relative; width:100%; max-width:min(90vw,45vh); margin:0 auto;">
      <button
        type="button"
        data-video-close
        aria-label="Close video"
        style="position:absolute; top:-3rem; right:0; background:none; border:0; cursor:pointer; color:#F4ECDB; line-height:1;"
      >
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
      <div style="position:relative; background:#000; border-radius:8px; overflow:hidden; aspect-ratio:9/16; box-shadow:0 24px 80px rgba(0,0,0,0.6);">
        <div id="video-iframe-container" style="position:absolute; inset:0;"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      // Video modal
      var modal = document.getElementById('video-modal');
      var container = document.getElementById('video-iframe-container');
      var openBtns = document.querySelectorAll('[data-video-open]');
      var closeBtns = document.querySelectorAll('[data-video-close]');
      var vimeoSrc = 'https://player.vimeo.com/video/1131081541?autoplay=1&title=0&byline=0&portrait=0&badge=0&autopause=0&player_id=0&app_id=58479';

      function openModal() {
        if (!modal || !container) return;
        container.innerHTML = '<iframe src="' + vimeoSrc + '" style="width:100%;height:100%;border:0;" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" referrerpolicy="strict-origin-when-cross-origin" title="Modular Garage Cabinet System"></iframe>';
        modal.style.display = 'flex';
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        if (!modal || !container) return;
        modal.style.display = 'none';
        modal.setAttribute('aria-hidden', 'true');
        container.innerHTML = '';
        document.body.style.overflow = '';
      }

      openBtns.forEach(function (b) { b.addEventListener('click', openModal); });
      closeBtns.forEach(function (b) { b.addEventListener('click', closeModal); });
      if (modal) {
        modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
      }
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal && modal.style.display !== 'none') closeModal();
      });

      // Mobile nav burger
      var burger = document.getElementById('nav-burger');
      var navLinks = document.getElementById('nav-links');
      if (burger && navLinks) {
        burger.addEventListener('click', function () {
          var isOpen = navLinks.style.display === 'flex';
          navLinks.style.display = isOpen ? '' : 'flex';
          navLinks.style.flexDirection = isOpen ? '' : 'column';
          navLinks.style.position = isOpen ? '' : 'absolute';
          navLinks.style.top = isOpen ? '' : '100%';
          navLinks.style.left = isOpen ? '' : '0';
          navLinks.style.right = isOpen ? '' : '0';
          navLinks.style.background = isOpen ? '' : 'var(--ink)';
          navLinks.style.padding = isOpen ? '' : '16px 24px 24px';
          navLinks.style.gap = isOpen ? '' : '0';
          navLinks.style.zIndex = isOpen ? '' : '100';
          burger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        });
      }
    })();
  </script>

</HomeLayout>
