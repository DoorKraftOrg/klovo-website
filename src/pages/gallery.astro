---
import PageLayout from '../layouts/PageLayout.astro';

const galleryItems = [
  { src: '/images/scenes/klovo-bright-garage.png', alt: 'Klovo garage cabinet set in a bright modern garage with bike and stairs', caption: 'Cabinet sets for the modern garage' },
  { src: '/images/scenes/full-system-bright.png', alt: 'Complete Klovo white cabinet system in a modern garage', caption: 'The full Klovo system — bike, golf bag, everything in its place' },
  { src: '/images/scenes/workspace-track-lights.png', alt: 'Klovo workspace with track lighting and organized tools', caption: 'Workshop-ready with track lighting and pegboard' },
  { src: '/images/assembly/hands-pressing.png', alt: 'Near-tool-free assembly — pressing cabinet panels together', caption: '2–3 minutes per box — just push and lock' },
  { src: '/images/scenes/base-wall-pegboard.png', alt: 'Base and wall cabinets with pegboard workspace', caption: 'Base cabinets and wall storage working together' },
  { src: '/images/retail/showroom-display.png', alt: 'Klovo cabinets on display in a retail showroom', caption: 'See Klovo in person at a retailer near you' },
];
---

<PageLayout
  title="Garage Gallery — Real Klovo Cabinet Sets"
  description="Real Klovo garage cabinet installations. See finished garages, workshops, mudrooms, home gyms, and home offices outfitted with modular Klovo sets."
  keywords="garage cabinet gallery, garage organization photos, finished garage, garage makeover, Klovo cabinet photos"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Real Garages</span>
      <h1 class="page-h1">See what's<br/><em>possible.</em></h1>
      <p class="page-lede">Klovo cabinet sets in home gyms, workshops, home offices, and every kind of garage in between.</p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="section section--cream">
    <div class="container">
      <div class="gallery-grid">
        {galleryItems.map((item) => (
          <figure class="gallery-card">
            <div class="gallery-card-img-wrap">
              <img
                src={item.src}
                alt={item.alt}
                class="gallery-card-img"
                loading="lazy"
              />
            </div>
            <figcaption class="gallery-card-caption">{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Community CTA -->
  <section class="section" style="background: var(--ink); text-align: center;">
    <div class="container">
      <span class="eyebrow" style="color: rgba(244,236,219,0.55);">Community</span>
      <h2 class="h-section" style="color: #FFFCF4;">Got a Klovo garage?<br/><em>Show it off.</em></h2>
      <p style="font-family: var(--sans); font-size: 17px; color: rgba(255,252,244,0.65); max-width: 480px; margin: 16px auto 0; line-height: 1.6;">
        Tag us on Instagram @klovostorage or email your photos to be featured.
      </p>
      <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 32px;">
        <a href="https://www.instagram.com/klovostorage/" target="_blank" rel="noopener noreferrer" class="btn btn--primary">Follow on Instagram &rarr;</a>
        <a href="/contact/" class="btn btn--ghost btn--ghost--dark">Submit Your Photos</a>
      </div>
    </div>
  </section>

</PageLayout>
