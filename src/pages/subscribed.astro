---
import PageLayout from '../layouts/PageLayout.astro';

const error = Astro.url.searchParams.get('error');
const isInvalid = error === 'invalid';
---

<PageLayout
  title="You're on the list"
  description="Thanks for joining the Klovo newsletter. Garage tips, new products, and the occasional dad joke."
>
  <section class="page-hero" style="text-align:center; min-height:50vh; display:flex; align-items:center;">
    <div class="container">
      {isInvalid && (
        <div style="display:inline-block; background:var(--amber); color:var(--ink); font-family:var(--sans); font-size:14px; font-weight:500; padding:10px 20px; border-radius:6px; margin-bottom:24px;">
          That email didn't look right — <a href="/" style="color:var(--ink); text-decoration:underline;">try again</a>.
        </div>
      )}
      <span class="eyebrow">You're in.</span>
      <h1 class="page-h1" style="margin:12px auto 0; max-width:520px;">Check your <em>inbox.</em></h1>
      <p style="font-family:var(--sans); color:var(--muted); font-size:17px; line-height:1.65; margin:16px auto 32px; max-width:440px;">
        We sent a welcome note to the address you entered. See you in the garage.
      </p>
      <a href="/" class="btn btn--primary">Back to Home &rarr;</a>
    </div>
  </section>
</PageLayout>
