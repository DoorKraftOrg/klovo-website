---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="For Retailers" description="Partner with Klovo. Premium garage cabinets that drive foot traffic, demos, and strong margins. Learn about our retail program.">

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
            Retail Partners
          </p>
          <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-6 leading-tight">
            The garage category is growing. Klovo is leading it.
          </h1>
          <p class="text-lg text-charcoal/70 leading-relaxed mb-6">
            Storage and organization is outpacing overall home improvement growth by 2x. Klovo's tool-free assembly creates in-store demo moments that convert browsers to buyers — and our 60-second build drives social sharing that extends your reach for free.
          </p>
          <a href="/contact/" class="btn-primary">
            Become a Partner <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="rounded-lg overflow-hidden shadow-xl">
            <img
              src="/images/hero/garage-hero.jpg"
              alt="Klovo cabinet display in retail setting"
              class="w-full h-auto"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Klovo -->
  <section class="py-20 lg:py-28 bg-warm-neutral">
    <div class="section-container">
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">Why retailers choose Klovo.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-pure-white rounded-lg p-8 reveal reveal-delay-1">
          <p class="stat-number text-3xl mb-3">60sec</p>
          <h3 class="text-lg font-semibold text-charcoal mb-2">Demo Moments</h3>
          <p class="text-klovo-grey text-[15px] leading-relaxed">
            Build a cabinet on the sales floor in 60 seconds. No other brand can match this in-store experience.
          </p>
        </div>

        <div class="bg-pure-white rounded-lg p-8 reveal reveal-delay-2">
          <p class="stat-number text-3xl mb-3">&lt;1%</p>
          <h3 class="text-lg font-semibold text-charcoal mb-2">Return Rate</h3>
          <p class="text-klovo-grey text-[15px] leading-relaxed">
            Quality construction and tool-free assembly eliminate the frustration that drives returns.
          </p>
        </div>

        <div class="bg-pure-white rounded-lg p-8 reveal reveal-delay-3">
          <p class="stat-number text-3xl mb-3">500+</p>
          <h3 class="text-lg font-semibold text-charcoal mb-2">Configurations</h3>
          <p class="text-klovo-grey text-[15px] leading-relaxed">
            Modular system means customers can start small and expand. Higher LTV, more repeat purchases.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section class="py-20 lg:py-28 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 reveal">
          <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">The Klovo dealer program.</h2>
          <p class="text-lg text-klovo-grey">Everything you need to succeed with Klovo.</p>
        </div>

        <div class="space-y-6 reveal">
          <div class="flex items-start gap-4 p-6 bg-warm-neutral rounded-lg">
            <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Competitive margins</h3>
              <p class="text-klovo-grey text-[15px]">Strong wholesale pricing with healthy retail margins. Volume incentives available.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-warm-neutral rounded-lg">
            <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Marketing support</h3>
              <p class="text-klovo-grey text-[15px]">Photography, copy, social assets, and co-op marketing programs to drive demand.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-warm-neutral rounded-lg">
            <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Display program</h3>
              <p class="text-klovo-grey text-[15px]">Pre-built display units that let customers touch, feel, and experience the tool-free assembly.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-warm-neutral rounded-lg">
            <svg class="w-6 h-6 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Training & support</h3>
              <p class="text-klovo-grey text-[15px]">Product training for your sales team, dedicated account management, and technical support.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-4">Ready to carry Klovo?</h2>
      <p class="text-lg text-klovo-grey max-w-lg mx-auto mb-8">
        Let's talk about what Klovo can do for your category.
      </p>
      <a href="/contact/" class="btn-amber">
        Start the Conversation <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

</BaseLayout>
