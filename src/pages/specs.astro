---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Specifications"
  description="Every spec that goes into a Klovo cabinet. Built for garages, not kitchens. Scratch-resistant laminate, sealed 1mm PVC edgebanding, 500 lbs per cabinet, 100% Made in USA."
>

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
          Specs
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          What makes a Klovo cabinet.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          Built for garages, not kitchens. Every spec that goes into a Klovo cabinet — on one page.
        </p>
      </div>
    </div>
  </section>

  <!-- Construction -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Construction</h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Panel material —</strong> scratch-resistant thermally fused laminate (TFL)</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Edgebanding —</strong> sealed 1mm PVC on all exposed edges</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Worktop option —</strong> TFL worktop available for base cabinets</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Depth —</strong> 18 inches (built for garages, not 24" kitchen-cabinet depth)</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Finish —</strong> premium white, furniture-grade</span>
            </li>
          </ul>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="rounded-lg overflow-hidden shadow-lg aspect-square">
            <img
              src="/images/assembly/edge-closeup.png"
              alt="Macro close-up of Klovo cabinet panel edge with sealed PVC edgebanding"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hardware -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Hardware</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <span><strong>Doors —</strong> soft-close hinges and push-to-open hardware</span>
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <span><strong>Drawers —</strong> push-to-open side-mount glides</span>
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <span><strong>Exterior hardware —</strong> none. Push-to-open means no handles to break or catch.</span>
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <span><strong>Back panel —</strong> secured with screws through runners</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Capacity -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-8">Capacity</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="bg-pure-white rounded-lg p-8 text-center">
            <p class="stat-number text-5xl mb-2">500</p>
            <p class="text-sm text-charcoal font-medium uppercase tracking-wider">lbs per cabinet</p>
          </div>
          <div class="bg-pure-white rounded-lg p-8 text-center">
            <p class="stat-number text-5xl mb-2">99</p>
            <p class="text-sm text-charcoal font-medium uppercase tracking-wider">lbs per drawer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Moisture & Durability -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Moisture & Durability</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Moisture-resistant design through sealed 1mm PVC edgebanding on all exposed edges
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Scratch-resistant laminate surface
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Built to handle garage conditions — humidity, temperature swings, condensation
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Assembly -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Assembly</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Panels interlock into a secure, weight-bearing construction
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Only tool required: screwdriver to secure the back panel
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            A single cabinet box assembles in about 2-3 minutes
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            A full set assembles in less than 1 hour
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Manufacturing & Warranty -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Manufacturing & Warranty</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            100% Made in USA
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            20 years of manufacturing experience (Door Kraft)
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            1-year limited warranty
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-8">See the full collection.</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/sets/" class="btn-primary">View Sets <span aria-hidden="true">&rarr;</span></a>
        <a href="/where-to-buy/" class="btn-secondary">Find a Retailer</a>
      </div>
    </div>
  </section>

</BaseLayout>
