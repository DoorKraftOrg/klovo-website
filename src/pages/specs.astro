---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Specifications"
  description="Every spec that goes into a Klovo cabinet. Built for garages, not kitchens. Moisture-resistant engineered wood, 1mm PVC edgebanding, 500 lbs per cabinet, 100% Made in USA."
>

  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <p class="text-klovo-amber font-semibold text-sm uppercase tracking-widest mb-4">
          Specs
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">
          What makes a Klovo cabinet.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed">
          Built for garages, not kitchens. Every spec that goes into a Klovo cabinet — on one page.
        </p>
      </div>
    </div>
  </section>

  <!-- Construction -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Construction</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Panels:</strong> 5/8" moisture-resistant, scratch-resistant engineered wood panels, edged with 1 mm PVC.</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Shelves, Doors & Drawer Fronts:</strong> Flat panel, 3/4" engineered wood, edged with 1 mm PVC.</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Interchangeability:</strong> Our doors and drawer kits (3, 4 or 5) can be swapped while keeping the same box. Applicable to 24" wide Base/Tall SKUs.</span>
            </li>
          </ul>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="rounded-lg overflow-hidden bg-pure-white p-6 shadow-sm">
            <img
              src="/images/specs/exploded-3-drawer.png"
              alt="Exploded view of a Klovo 3-drawer base cabinet showing panels, drawers, hinges, and toe kick"
              class="w-full h-auto object-contain"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hardware & Drawer -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Hardware & Drawer</h2>
        <ul class="space-y-4">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <span><strong>Drawer Glides:</strong> Push-to-open ball-bearing drawer glides (no hardware needed).</span>
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            <span><strong>Hinges:</strong> Soft-close hinges, push-to-open hardware also provided for doors.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Support & Stability -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal lg:order-2">
          <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Support & Stability</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Folding Plastic Leg:</strong> Waterproof plastic leg levelers 3½" H to 6" H adjustment range.</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>Waterproof Toe Kick:</strong> Clip-on system with extruded aluminum finish and made of polypropylene and a rubber gasket, 4" high.</span>
            </li>
            <li class="flex items-start gap-3 text-charcoal/80">
              <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              <span><strong>90° Connector Fitting & End Cap:</strong> 4" H matching aluminum foil finish.</span>
            </li>
          </ul>
        </div>
        <div class="reveal reveal-delay-1 lg:order-1">
          <div class="rounded-lg overflow-hidden bg-pure-white p-6 shadow-sm">
            <img
              src="/images/specs/exploded-3-drawer-shelf.png"
              alt="Exploded view of a Klovo 3-drawer base cabinet with additional shelf — showing panel, shelf, glides, hinges, leg levelers, and toe kick"
              class="w-full h-auto object-contain"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capacity -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-8">Capacity</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="bg-warm-neutral rounded-lg p-8 text-center">
            <p class="stat-number text-5xl mb-2">500</p>
            <p class="text-sm text-charcoal font-medium uppercase tracking-wider">lbs per cabinet</p>
          </div>
          <div class="bg-warm-neutral rounded-lg p-8 text-center">
            <p class="stat-number text-5xl mb-2">99</p>
            <p class="text-sm text-charcoal font-medium uppercase tracking-wider">lbs per drawer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Assembly -->
  <section class="py-16 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Assembly</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Panels interlock into a secure, weight-bearing construction
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            Only tool required: screwdriver to secure the back panel
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            A single cabinet box assembles in about 2-3 minutes
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            A full set assembles in less than 1 hour
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Manufacturing & Warranty -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Manufacturing & Warranty</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            100% Made in USA
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            20 years of manufacturing experience (Door Kraft)
          </li>
          <li class="flex items-start gap-3 text-charcoal/80">
            <svg class="w-5 h-5 text-klovo-amber flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
            1-year limited warranty
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-warm-neutral">
    <div class="section-container text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-8">See the full collection.</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/sets/" class="btn-primary">View Sets <span aria-hidden="true">&rarr;</span></a>
        <a href="/downloads/klovo-brochure.pdf" download class="btn-amber">Download Brochure <span aria-hidden="true">&darr;</span></a>
        <a href="/where-to-buy/" class="btn-secondary">Find a Retailer</a>
      </div>
    </div>
  </section>

</BaseLayout>
