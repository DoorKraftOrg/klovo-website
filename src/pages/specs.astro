---
import PageLayout from '../layouts/PageLayout.astro';

const SPECS = [
  { letter: 'A', group: 'Construction', title: 'Panels',
    detail: '5/8" moisture-resistant, scratch-resistant engineered wood panels, edged with 1 mm PVC.' },
  { letter: 'B', group: 'Construction', title: 'Shelves, Doors & Drawer Fronts',
    detail: 'Flat panel, 3/4" engineered wood, edged with 1 mm PVC.' },
  { letter: 'C', group: 'Construction', title: 'Interchangeability',
    detail: 'Our doors and drawer kits (3, 4 or 5) can be swapped while keeping the same box. Applicable to 24" wide Base/Tall SKUs.' },
  { letter: 'D', group: 'Hardware & Drawer', title: 'Drawer Glides',
    detail: 'Push-to-open ball-bearing drawer glides (no hardware needed).' },
  { letter: 'E', group: 'Hardware & Drawer', title: 'Hinges',
    detail: 'Soft-close hinges, push-to-open hardware also provided for doors.' },
  { letter: 'F', group: 'Support & Stability', title: 'Folding Plastic Leg',
    detail: 'Waterproof plastic leg levelers 3½" H to 6" H adjustment range.' },
  { letter: 'G', group: 'Support & Stability', title: 'Waterproof Toe Kick',
    detail: 'Clip-on system with extruded aluminum finish and made of polypropylene and a rubber gasket, 4" high.' },
  { letter: 'H', group: 'Support & Stability', title: '90° Connector Fitting & End Cap',
    detail: '4" H matching aluminum foil finish.' },
];

const GROUPS = ['Construction', 'Hardware & Drawer', 'Support & Stability'] as const;
---

<PageLayout
  title="Garage Cabinet Specifications — Materials, Hardware, Load"
  description="Klovo modular garage cabinet specs: engineered wood panels, 1mm PVC edgebanding, 500 lb per cabinet, 99 lb per drawer, push-to-open hardware. One page, no fluff."
  keywords="garage cabinet specifications, engineered wood garage cabinets, modular garage cabinets, push-to-open hardware, soft-close hinges, ball-bearing drawer glides, garage cabinet load capacity"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Spec Sheet</span>
      <h1 class="page-h1" style="margin-top: 16px;">Built for the garage.<br/><em>Every inch of it.</em></h1>
      <p class="page-lede">
        Every part of a Klovo cabinet — what it's made of, how it holds, and why it lasts. One page. No marketing fluff.
      </p>

      <!-- Stat Ribbon -->
      <div class="page-stat-row">
        <div class="page-stat">
          <div class="page-stat-val">500</div>
          <div class="page-stat-label">lb / cabinet</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-val">99</div>
          <div class="page-stat-label">lb / drawer</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-val">3 min</div>
          <div class="page-stat-label">assembly per box</div>
        </div>
        <div class="page-stat">
          <div class="page-stat-val">100%</div>
          <div class="page-stat-label">made in USA</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Anatomy -->
  <section class="section section--cream">
    <div class="container">
      <span class="page-label" data-num="01">Anatomy</span>
      <p style="font-family: var(--sans); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-top: 16px;">Reference: DB324 · 24″ Drawer Base</p>
      <div style="margin-top: 24px; max-width: 980px;">
        <img
          src="/images/specs/cabinet-anatomy.png"
          alt="Exploded view of a Klovo drawer base cabinet with parts labeled A through H"
          style="display:block; width:100%; height:auto;"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Legend -->
  <section class="section" style="background: var(--paper);">
    <div class="container">
      {GROUPS.map((g) => (
        <div style="margin-bottom: 48px;">
          <div style="display:flex; align-items:center; gap:16px; margin-bottom:24px;">
            <div style="flex:1; height:1px; background:var(--line);"></div>
            <span style="font-family:var(--sans); font-size:11px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:var(--ink);">{g}</span>
            <div style="flex:1; height:1px; background:var(--line);"></div>
          </div>
          <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:12px;">
            {SPECS.filter((s) => s.group === g).map((s) => (
              <div class="page-card" style="display:flex; gap:16px;">
                <span style="display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; background:var(--amber); color:var(--ink); font-family:var(--sans); font-weight:700; font-size:14px; flex-shrink:0;">
                  {s.letter}
                </span>
                <div>
                  <div style="font-family:var(--sans); font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--muted); margin-bottom:4px;">{s.group}</div>
                  <div style="font-family:var(--serif); font-size:17px; font-weight:400; color:var(--ink); line-height:1.2;">{s.title}</div>
                  <div style="font-family:var(--sans); font-size:13.5px; color:var(--ink-soft); line-height:1.55; margin-top:6px;">{s.detail}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Interchangeability -->
  <section class="section" style="background: var(--neutral);">
    <div class="container">
      <div class="split" style="align-items: center;">
        <div class="split-text">
          <span class="eyebrow">Interchangeability</span>
          <h2 class="h-section" style="margin-top: 20px;">Same box.<br/><em>Different insides.</em></h2>
          <p style="font-family:var(--sans); font-size:16px; color:var(--ink-soft); line-height:1.6; margin-top:20px;">
            Every 24″ Base or Tall SKU accepts an open shelf, a full-height door, or a 3, 4, or 5-drawer kit. Change the setup without changing the cabinet.
          </p>
          <div style="margin-top:16px; display:inline-block; font-family:var(--sans); font-size:11px; font-weight:600; letter-spacing:0.18em; text-transform:uppercase; color:var(--muted); border:1px solid var(--line); padding:6px 12px;">
            Applies to 24″ Base / Tall
          </div>
        </div>
        <div class="split-media">
          <div style="display:flex; align-items:flex-end; justify-content:center; gap:12px; padding:24px 0;">
            {[
              { label: 'B24-OS', caption: 'Open + shelf', kind: 'shelf' },
              { label: 'B24',    caption: 'Door',         kind: 'door' },
              { label: 'DB324',  caption: '3 drawers',    kind: 'drawers', count: 3 },
              { label: 'DB424',  caption: '4 drawers',    kind: 'drawers', count: 4 },
              { label: 'DB524',  caption: '5 drawers',    kind: 'drawers', count: 5 },
            ].map((b, i, arr) => (
              <>
                <div style="display:flex; flex-direction:column; align-items:center; flex:1; min-width:0;">
                  <div style="font-family:var(--sans); font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--muted); margin-bottom:8px;">{b.label}</div>
                  <div style="width:100%; background:#fff; border:1.5px solid var(--ink); aspect-ratio:3/4; position:relative;">
                    <div style="position:absolute; inset:3px;">
                      {b.kind === 'drawers' && (
                        <div style="height:100%; width:100%; display:flex; flex-direction:column; gap:3px;">
                          {Array.from({ length: b.count! }).map(() => (
                            <div style="flex:1; background:var(--paper); border:1px solid var(--line); display:flex; align-items:center; justify-content:center;">
                              <div style="width:18px; height:2px; background:var(--ink); opacity:0.4;"></div>
                            </div>
                          ))}
                        </div>
                      )}
                      {b.kind === 'door' && (
                        <div style="height:100%; width:100%; background:var(--paper); border:1px solid var(--line); position:relative;">
                          <div style="position:absolute; top:6px; bottom:6px; left:50%; width:0; border-left:1px dashed var(--line);"></div>
                          <div style="position:absolute; right:8px; top:50%; width:3px; height:3px; border-radius:50%; background:var(--ink); opacity:0.4;"></div>
                        </div>
                      )}
                      {b.kind === 'shelf' && (
                        <div style="height:100%; width:100%; display:flex; flex-direction:column; gap:3px;">
                          <div style="flex:1; border:1px dashed var(--line);"></div>
                          <div style="height:4px; background:var(--ink); opacity:0.7;"></div>
                          <div style="flex:1; border:1px dashed var(--line);"></div>
                        </div>
                      )}
                    </div>
                  </div>
                  <div style="margin-top:8px; font-family:var(--sans); font-size:11px; font-weight:600; color:var(--ink); text-align:center; text-transform:uppercase; letter-spacing:0.1em;">
                    {b.caption}
                  </div>
                </div>
                {i < arr.length - 1 && (
                  <div style="align-self:center; padding-top:32px;">
                    <svg width="20" height="16" viewBox="0 0 32 20" aria-hidden="true">
                      <path d="M0 10 H32 M24 4 L32 10 L24 16" stroke="var(--amber)" stroke-width="1.5" fill="none" />
                    </svg>
                  </div>
                )}
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Materials Table -->
  <section class="section section--cream">
    <div class="container">
      <span class="eyebrow">Materials</span>
      <div style="margin-top: 32px; overflow-x: auto;">
        <table class="page-table">
          <thead>
            <tr>
              <th>Component</th>
              <th class="hide-mobile">Material</th>
              <th>Thickness</th>
              <th>Edge</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Panels (sides, bottom, top)</strong></td><td class="hide-mobile">Moisture-resistant engineered wood</td><td>5/8″</td><td>1 mm PVC</td></tr>
            <tr><td><strong>Shelves</strong></td><td class="hide-mobile">Engineered wood</td><td>3/4″</td><td>1 mm PVC</td></tr>
            <tr><td><strong>Doors</strong></td><td class="hide-mobile">Flat-panel engineered wood</td><td>3/4″</td><td>1 mm PVC</td></tr>
            <tr><td><strong>Drawer fronts</strong></td><td class="hide-mobile">Flat-panel engineered wood</td><td>3/4″</td><td>1 mm PVC</td></tr>
            <tr><td><strong>Toe kick</strong></td><td class="hide-mobile">Polypropylene + rubber gasket</td><td>4″ H</td><td>Aluminum foil finish</td></tr>
            <tr><td><strong>Leg leveler</strong></td><td class="hide-mobile">Waterproof plastic</td><td>3½″–6″</td><td>—</td></tr>
            <tr><td><strong>End cap / 90° fit</strong></td><td class="hide-mobile">Polypropylene + aluminum finish</td><td>—</td><td>Matching foil</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Finish swatch -->
      <div style="margin-top: 20px; display:flex; align-items:center; gap:16px; border:1px solid var(--line); padding: 16px 20px; background:var(--paper);">
        <div style="width:48px; height:48px; background:#F5F2EC; border:1px solid var(--line); flex-shrink:0;"></div>
        <div>
          <div style="font-family:var(--sans); font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--muted);">Finish</div>
          <div style="font-family:var(--serif); font-size:18px; font-weight:400; color:var(--ink); margin-top:2px;">Perfect White</div>
          <div style="font-family:var(--sans); font-size:13px; color:var(--ink-soft); margin-top:4px;">Slab doors &amp; drawers, engineered-wood core, ships flat with all hardware.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Origin + Warranty (dark section) -->
  <section class="section" style="background: #1F1B14;">
    <div class="container">
      <div class="split" style="align-items: center;">
        <div class="split-text">
          <span style="font-family:var(--sans); font-size:13px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:var(--amber);">Origin · Warranty</span>
          <h2 style="font-family:var(--display); font-size:clamp(28px,3.5vw,44px); font-weight:600; color:#FFFCF4; line-height:1.05; letter-spacing:-0.02em; margin:16px 0 24px;">Made in Georgia.<br/><em style="font-style:normal; font-weight:800; color:#F2A427;">Built to last.</em></h2>
          <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:20px; max-width:480px;">
            {[
              ['20+', 'yrs by Door Kraft'],
              ['100%', 'USA made'],
              ['1 yr', 'limited warranty'],
            ].map(([n, l]) => (
              <div style="border-left:2px solid var(--amber); padding-left:12px;">
                <div style="font-family:var(--display); font-weight:700; font-size:clamp(22px,3vw,28px); color:#fff; line-height:1;">{n}</div>
                <div style="font-family:var(--sans); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--amber); margin-top:6px;">{l}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="split-media">
          <div style="font-family:var(--sans); font-size:11px; font-weight:600; letter-spacing:0.18em; text-transform:uppercase; color:var(--amber); margin-bottom:16px;">Downloads</div>
          <a href="/downloads/klovo-brochure.pdf" style="display:flex; align-items:center; justify-content:space-between; padding:14px 0; border-bottom:1px solid rgba(248,245,240,0.12); color:#fff; text-decoration:none;">
            <div>
              <div style="font-family:var(--sans); font-weight:600; font-size:15px;">Retail brochure (PDF)</div>
              <div style="font-family:var(--sans); font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(248,245,240,0.5); margin-top:4px;">4 pages · 2 MB</div>
            </div>
            <span style="color:var(--amber); font-size:20px;">↓</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="page-cta-band">
    <div class="container">
      <span class="eyebrow" style="color: rgba(244,236,219,0.55);">Explore</span>
      <h2 class="h-final">Explore the<br/><em>full collection.</em></h2>
      <div class="page-cta-btns">
        <a href="/sets/" class="btn btn--primary">View sets &rarr;</a>
        <a href="/where-to-buy/" class="btn btn--ghost btn--ghost--dark">Find a retailer</a>
      </div>
    </div>
  </section>

  <style>
    .hide-mobile { display: table-cell; }
    @media (max-width: 640px) {
      .hide-mobile { display: none; }
    }
  </style>

</PageLayout>
