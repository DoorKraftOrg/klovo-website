---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allSets = await getCollection('sets');
const sets = allSets
  .map((s) => ({ id: s.id, ...s.data }))
  .sort((a, b) => a.order - b.order);

const TAG_META: Record<string, { label: string; blurb: string }> = {
  'home-gym':    { label: 'Home Gym',    blurb: 'Lockers, racks, open display.' },
  workshop:      { label: 'Workshop',    blurb: 'Worktop, drawers, pegboard.' },
  storage:       { label: 'Storage',     blurb: 'Closed bases, overheads, lockers.' },
  'family-hub':  { label: 'Family Hub',  blurb: 'Bench seating, cubbies, overhead.' },
  mudroom:       { label: 'Mudroom',     blurb: 'Drop zone, hooks, seating.' },
  'home-office': { label: 'Home Office', blurb: 'Continuous worktop, drawer base.' },
};

const tagOrder = ['home-gym', 'workshop', 'storage', 'family-hub', 'mudroom', 'home-office'];
const activeTagsInData = tagOrder.filter((t) =>
  sets.some((s) => (s.useCaseTags ?? []).includes(t))
);

const fmtPrice = (n: number) => `$${n.toLocaleString('en-US')}`;
const primaryTag = (s: any) => (s.useCaseTags?.[0] ?? 'storage') as string;
const primaryTagLabel = (s: any) => TAG_META[primaryTag(s)]?.label ?? '';

// ----- Per-set BOM (column-level SKU breakdown) used to draw real schematics -----
type Col = { tall?: string; upper?: string; base?: string; worktop?: boolean; width?: number };
type BomEntry = { sku: string; cols: Col[] };
const BOM: BomEntry[] = [
  { sku: '01-2f-1p-WHT',   cols: [{ tall: 'UC2484' }] },
  { sku: '02-4f-2p-WHT',   cols: [{ tall: 'UC2484' }, { upper: 'W2430', width: 24 }] },
  { sku: '03-6f-3p-WHT',   cols: [{ upper: 'W3630', worktop: true, base: 'B18-OS', width: 36 }, { worktop: true, base: 'B18-OS', width: 36 }] },
  { sku: '04-6f-4p-WHT',   cols: [{ upper: 'W3630-OS', worktop: true, base: 'B24-OS', width: 36 }, { worktop: true, base: 'B24-OS', width: 36 }] },
  { sku: '05-8f-5p-WHT',   cols: [{ upper: 'W3630', worktop: true, base: 'B24-OS', width: 36 }, { worktop: true, base: 'B24-OS', width: 36 }, { tall: 'UC2484' }] },
  { sku: '06-8f-6p-WHT',   cols: [{ upper: 'W2430', worktop: true, base: 'DB324', width: 24 }, { upper: 'W2430', worktop: true, base: 'B24-FH', width: 24 }, { tall: 'UC2484' }] },
  { sku: '07-8f-6p-WHT',   cols: [{ upper: 'W3630', worktop: true, base: 'B36-FH', width: 36 }, { upper: 'W3630', worktop: true, base: 'B36-FH', width: 36 }] },
  { sku: '08-8f-6p-WHT',   cols: [{ upper: 'W3630', worktop: true, base: 'DB424', width: 36 }, { upper: 'W3630', worktop: true, base: 'B24-FH', width: 36 }] },
  { sku: '09-10f-6p-WHT',  cols: [{ tall: 'UC2484' }, { upper: 'W3630', worktop: true, base: 'B36-OS', width: 36 }, { worktop: true, base: 'B36-OS', width: 36 }] },
  { sku: '10-10f-7p-WHT',  cols: [{ upper: 'W3630', worktop: true, base: 'DB424', width: 36 }, { upper: 'W3630', worktop: true, base: 'B24-FH', width: 36 }, { tall: 'UC2484' }] },
  { sku: '11-10f-7p-WHT',  cols: [{ upper: 'W3630', worktop: true, base: 'B36-OS', width: 36 }, { upper: 'W3630', worktop: true, base: 'B36-OS', width: 36 }, { tall: 'UC2484DB3' }] },
  { sku: '12-10f-8p-WHT',  cols: [{ upper: 'W3630', worktop: true, base: 'DB524', width: 36 }, { upper: 'W3630', worktop: true, base: 'DB524', width: 36 }, { worktop: true, base: 'B24-FH', width: 24 }, { tall: 'UC2484' }] },
  { sku: '13-12f-8p-WHT',  cols: [{ tall: 'UC2484' }, { tall: 'UC2484' }, { upper: 'W3630', worktop: true, base: 'B36-FH', width: 36 }, { upper: 'W3630', worktop: true, base: 'B36-OS', width: 36 }] },
  { sku: '14-14f-9p-WHT',  cols: [{ upper: 'W3630', worktop: true, base: 'DB324', width: 36 }, { upper: 'W3630', worktop: true, base: 'B24-FH', width: 36 }, { tall: 'UC2484' }, { tall: 'UC2484' }, { tall: 'UC2484' }] },
  { sku: '15-15f-10p-WHT', cols: [{ tall: 'UC2484' }, { tall: 'UC2484' }, { tall: 'UC2484' }, { upper: 'W3630', worktop: true, base: 'DB424', width: 36 }, { upper: 'W3630', worktop: true, base: 'DB424', width: 36 }, { worktop: true, base: 'B24-FH', width: 24 }] },
  { sku: '16-16f-8p-WHT',  cols: [{ tall: 'UC2484' }, { tall: 'UC2484' }, { tall: 'UC2484DB3' }, { tall: 'UC2484' }, { tall: 'UC2484DB3' }, { tall: 'UC2484' }, { tall: 'UC2484' }, { tall: 'UC2484' }] },
];
const bomBySku: Record<string, BomEntry> = Object.fromEntries(BOM.map((b) => [b.sku, b]));

// ----- BOM-driven SVG renderer. All coords in inches. y=0 top, y=96 floor. -----
type DiagramOpts = { accent?: boolean; compact?: boolean };
function diagramSvg(set: any, opts: DiagramOpts = {}): string {
  const { accent = false, compact = false } = opts;
  const bom = bomBySku[set.sku];
  if (!bom) return '';
  const FLOOR = 96;
  const ENVELOPE_IN = 16 * 12;
  const stroke = '#272727';
  const wall = '#E8E2D9';
  const blue = '#0E4C8B';
  const amber = '#F7C948';

  const cols = bom.cols.map((c) => ({
    tall: c.tall ?? null,
    upper: c.upper ?? null,
    base: c.base ?? null,
    worktop: !!c.worktop,
    width: c.width ?? 24,
  }));
  const totalIn = cols.reduce((a, c) => a + c.width, 0);
  const offset = Math.max(0, (ENVELOPE_IN - totalIn) / 2);

  let cursor = offset;
  const placed = cols.map((c) => {
    const x = cursor;
    cursor += c.width;
    return { ...c, x };
  });

  // worktop runs (consecutive worktop cols merge into a single slab)
  const runs: Array<{ x0: number; x1: number }> = [];
  let run: { x0: number; x1: number } | null = null;
  for (const c of placed) {
    if (c.worktop) {
      if (!run) run = { x0: c.x, x1: c.x + c.width };
      else run.x1 = c.x + c.width;
    } else if (run) { runs.push(run); run = null; }
  }
  if (run) runs.push(run);

  const parts: string[] = [];
  parts.push(`<rect x="0" y="0" width="${ENVELOPE_IN}" height="${FLOOR}" fill="${wall}" opacity="0.22"/>`);
  if (!compact) {
    for (let i = 0; i <= 8; i++) {
      const tx = i * 24;
      parts.push(`<line x1="${tx}" y1="${FLOOR}" x2="${tx}" y2="${FLOOR + 1.8}" stroke="${stroke}" stroke-width="0.4" opacity="0.4"/>`);
    }
  }
  parts.push(`<line x1="0" y1="${FLOOR}" x2="${ENVELOPE_IN}" y2="${FLOOR}" stroke="${stroke}" stroke-width="0.6"/>`);

  for (const c of placed) {
    const x = c.x, w = c.width;

    if (c.tall) {
      const h = 84;
      const top = FLOOR - h;
      const drawers = c.tall === 'UC2484DB3' ? 3 : c.tall === 'UC2484DB4' ? 4 : c.tall === 'UC2484DB5' ? 5 : 0;
      const drawerBandH = drawers * 6;
      const drawerTop = FLOOR - drawerBandH;
      parts.push(`<rect x="${x}" y="${top}" width="${w}" height="${h}" fill="#FFFFFF" stroke="${stroke}" stroke-width="0.6"/>`);
      parts.push(`<line x1="${x + w / 2}" y1="${top + 1}" x2="${x + w / 2}" y2="${drawers ? drawerTop - 1 : FLOOR - 1}" stroke="${stroke}" stroke-width="0.4"/>`);
      if (drawers > 0) {
        parts.push(`<line x1="${x}" y1="${drawerTop}" x2="${x + w}" y2="${drawerTop}" stroke="${stroke}" stroke-width="0.6"/>`);
        for (let i = 0; i < drawers - 1; i++) {
          const dy = drawerTop + (i + 1) * (drawerBandH / drawers);
          parts.push(`<line x1="${x}" y1="${dy}" x2="${x + w}" y2="${dy}" stroke="${stroke}" stroke-width="0.35"/>`);
        }
      }
    }

    if (c.upper) {
      const h = 30;
      const top = FLOOR - 90; // upper top edge at 90"
      const openShelf = c.upper === 'W3630-OS';
      parts.push(`<rect x="${x}" y="${top}" width="${w}" height="${h}" fill="${openShelf ? '#F8F5F0' : '#FFFFFF'}" stroke="${stroke}" stroke-width="0.6"/>`);
      if (openShelf) {
        parts.push(`<line x1="${x + 1}" y1="${top + h / 2}" x2="${x + w - 1}" y2="${top + h / 2}" stroke="${stroke}" stroke-width="0.4"/>`);
      } else {
        parts.push(`<line x1="${x + w / 2}" y1="${top + 1}" x2="${x + w / 2}" y2="${top + h - 1}" stroke="${stroke}" stroke-width="0.4"/>`);
      }
    }

    if (c.base) {
      const h = 34.5;
      const top = FLOOR - h;
      const openShelf = c.base.endsWith('-OS');
      const drawers = c.base === 'DB324' ? 3 : c.base === 'DB424' ? 4 : c.base === 'DB524' ? 5 : 0;
      const door = c.base.endsWith('-FH');
      parts.push(`<rect x="${x}" y="${top}" width="${w}" height="${h}" fill="${openShelf ? '#F8F5F0' : '#FFFFFF'}" stroke="${stroke}" stroke-width="0.6"/>`);
      parts.push(`<rect x="${x}" y="${FLOOR - 4}" width="${w}" height="4" fill="${wall}" stroke="${stroke}" stroke-width="0.4"/>`);
      if (openShelf) {
        parts.push(`<line x1="${x + 1}" y1="${top + h / 2 - 3}" x2="${x + w - 1}" y2="${top + h / 2 - 3}" stroke="${stroke}" stroke-width="0.35"/>`);
      }
      if (door) {
        parts.push(`<line x1="${x + w / 2}" y1="${top + 1}" x2="${x + w / 2}" y2="${FLOOR - 5}" stroke="${stroke}" stroke-width="0.4"/>`);
      }
      if (drawers > 0) {
        for (let i = 1; i < drawers; i++) {
          const dy = top + (i * (h - 4) / drawers);
          parts.push(`<line x1="${x}" y1="${dy}" x2="${x + w}" y2="${dy}" stroke="${stroke}" stroke-width="0.35"/>`);
        }
      }
    }
  }

  // worktop slabs
  for (const r of runs) {
    const y = FLOOR - 36;
    parts.push(`<rect x="${r.x0 - 0.5}" y="${y}" width="${r.x1 - r.x0 + 1}" height="1.5" fill="${accent ? amber : stroke}"/>`);
  }

  // set width underline
  if (totalIn > 0) {
    parts.push(`<line x1="${offset}" y1="${FLOOR + 2.5}" x2="${offset + totalIn}" y2="${FLOOR + 2.5}" stroke="${accent ? amber : blue}" stroke-width="1.2"/>`);
  }

  return `<svg viewBox="0 0 ${ENVELOPE_IN} ${FLOOR + 6}" preserveAspectRatio="xMidYMax meet" class="w-full h-full" style="overflow: visible">${parts.join('')}</svg>`;
}

// Client-side dataset: keep minimal
const clientSets = sets.map((s) => ({
  id: s.id,
  title: s.title,
  widthFt: s.widthFt,
  pieces: s.pieces,
  drawers: s.drawers,
  msrp: s.msrp,
  tags: s.useCaseTags ?? [],
  primaryLabel: primaryTagLabel(s),
}));

const defaultWall = 8;
---

<BaseLayout
  title="Sets"
  description="Pre-designed Klovo garage cabinet sets from 2 ft to 16 ft. 500 lbs per cabinet, moisture-resistant, 100% Made in USA."
>
  <!-- Hero -->
  <section class="pt-12 lg:pt-20 pb-8 lg:pb-10 bg-warm-white">
    <div class="section-container">
      <div class="max-w-3xl">
        <p class="text-klovo-amber font-semibold text-sm uppercase mb-3" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
          The Collection
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-charcoal mb-5 leading-[1.05]" style="letter-spacing: -0.02em;">
          Start with your wall.
        </h1>
        <p class="text-lg text-klovo-grey leading-relaxed max-w-2xl">
          Klovo sets run from 2 to 16 feet in 2-foot increments. Drag the ruler to match your wall — we'll show you every set that fits.
        </p>
      </div>
    </div>
  </section>

  <!-- Width scrubber (full-width row) -->
  <section class="pb-6 lg:pb-10 bg-warm-white">
    <div class="section-container">
      <div class="rounded-lg p-6 md:p-10 bg-pure-white" style="border: 1px solid #E8E2D9;">
        <div class="grid grid-cols-1 md:grid-cols-[auto_minmax(0,1fr)] gap-6 md:gap-10 items-center">
          <div class="flex items-baseline gap-3">
            <span id="wall-ft-label" class="text-6xl md:text-7xl font-bold text-charcoal" style="font-family: 'Orbitron', sans-serif; line-height: 1;">
              {defaultWall}
            </span>
            <span class="text-xl text-klovo-grey" style="font-family: 'Oxanium', monospace;">ft wall</span>
          </div>
          <div>
            <input
              id="wall-ft-input"
              type="range"
              min="2"
              max="16"
              step="2"
              value={defaultWall}
              class="klovo-range w-full"
              aria-label="Wall width in feet"
            />
            <div id="wall-ft-ticks" class="flex justify-between mt-3 text-[11px] uppercase" style="font-family: 'Oxanium', monospace; color: #858485; letter-spacing: 0.12em;">
              {[2,4,6,8,10,12,14,16].map((n) => (
                <span data-ft={n} class={n === defaultWall ? 'text-klovo-blue font-semibold' : ''}>{n}′</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Matching sets at selected width -->
  <section class="py-10 lg:py-16 bg-warm-white">
    <div class="section-container">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-8">
        <div>
          <p class="text-klovo-amber font-semibold text-sm uppercase mb-2" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
            Fits your wall
          </p>
          <h2 class="text-2xl md:text-3xl font-bold text-charcoal" style="letter-spacing: -0.02em;">
            <span id="match-count">0</span> sets at <span id="match-ft">{defaultWall}</span> ft
          </h2>
        </div>
        <p id="match-fallback" class="hidden spec-mono text-[11px] text-klovo-grey" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;"></p>
      </div>

      <div id="match-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {sets.map((s) => (
          <a
            href={`/sets/${s.id}/`}
            class="match-card group block"
            data-match-width={s.widthFt}
          >
            <div class="bg-pure-white rounded-lg overflow-hidden h-full flex flex-col transition-shadow group-hover:shadow-lg" style="border: 1px solid #E8E2D9;">
              <div class="p-4 pb-2 flex items-center justify-between">
                <span class="text-[11px] uppercase text-klovo-grey" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
                  {s.widthFt} ft · {s.pieces} pc
                </span>
                <span class="text-[11px] uppercase text-klovo-blue font-semibold" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
                  {primaryTagLabel(s)}
                </span>
              </div>
              {s.imagesAvailable ? (
                <div class="img-zoom-container aspect-[16/10] bg-warm-neutral">
                  <img src={s.image} alt={s.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              ) : (
                <div class="px-4" style="height: 140px;" set:html={diagramSvg(s, { accent: true, compact: true })} />
              )}
              <div class="p-5 pt-3 border-t flex-1 flex flex-col" style="border-color: #E8E2D9;">
                <div class="flex items-baseline justify-between gap-4 mb-1">
                  <h3 class="text-lg font-semibold text-charcoal group-hover:text-klovo-blue transition-colors leading-tight">
                    {s.title}
                  </h3>
                  <span class="text-klovo-blue font-bold shrink-0" style="font-family: 'Orbitron', sans-serif;">
                    {fmtPrice(s.msrp)}
                  </span>
                </div>
                <p class="text-[14px] text-klovo-grey leading-snug mb-4">
                  {(s.specialFeatures ?? []).slice(0, 2).join(' · ') || (s.imagesAvailable ? '' : 'Image coming soon')}
                </p>
                <span class="mt-auto inline-flex items-center gap-1 text-klovo-blue font-semibold text-sm">
                  View this set <span aria-hidden="true">→</span>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Filter + grid -->
  <section class="py-12 lg:py-20 bg-warm-neutral">
    <div class="section-container">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-10">
        <div>
          <p class="text-klovo-amber font-semibold text-sm uppercase mb-2" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
            All sets
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-charcoal" style="letter-spacing: -0.02em;">
            <span id="grid-count">{sets.length}</span> sets, 2 to 16 ft.
          </h2>
        </div>
        <div id="tag-filters" class="flex flex-wrap gap-2">
          <button type="button" data-tag="all" class="tag-chip px-4 py-2 text-sm font-medium rounded-full on">All</button>
          {activeTagsInData.map((t) => (
            <button type="button" data-tag={t} class="tag-chip px-4 py-2 text-sm font-medium rounded-full">
              {TAG_META[t].label}
            </button>
          ))}
        </div>
      </div>

      <div id="sets-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {sets.map((s) => (
          <a
            href={`/sets/${s.id}/`}
            class="set-card group block"
            data-tags={(s.useCaseTags ?? []).join(',')}
          >
            <div class="bg-pure-white rounded-lg overflow-hidden transition-shadow group-hover:shadow-lg" style="border: 1px solid #E8E2D9;">
              <div class="p-4 pb-2 flex items-center justify-between">
                <span class="text-[11px] uppercase text-klovo-grey" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
                  {s.widthFt} ft · {s.pieces} pc
                </span>
                <span class="text-[11px] uppercase text-klovo-blue font-semibold" style="font-family: 'Oxanium', monospace; letter-spacing: 0.18em;">
                  {primaryTagLabel(s)}
                </span>
              </div>
              {s.imagesAvailable ? (
                <div class="img-zoom-container aspect-[16/10] bg-warm-neutral">
                  <img src={s.image} alt={s.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              ) : (
                <div class="px-4" style="height: 120px;" set:html={diagramSvg(s, { compact: true })} />
              )}
              <div class="p-5 pt-3 border-t" style="border-color: #E8E2D9;">
                <div class="flex items-baseline justify-between gap-4 mb-1">
                  <h3 class="text-lg font-semibold text-charcoal group-hover:text-klovo-blue transition-colors leading-tight">
                    {s.title}
                  </h3>
                  <span class="text-klovo-blue font-bold shrink-0" style="font-family: 'Orbitron', sans-serif;">
                    {fmtPrice(s.msrp)}
                  </span>
                </div>
                <p class="text-[14px] text-klovo-grey leading-snug">
                  {(s.specialFeatures ?? []).slice(0, 2).join(' · ') || (s.imagesAvailable ? '' : 'Image coming soon')}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div id="empty-state" class="hidden text-center py-16 text-klovo-grey">
        No sets match that filter. Try a different category or width.
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-warm-white">
    <div class="section-container text-center">
      <h2 class="text-3xl font-bold text-charcoal mb-4" style="letter-spacing: -0.02em;">Ready to transform your garage?</h2>
      <a href="/where-to-buy/" class="btn-primary">Find a Retailer <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <style>
    .klovo-range {
      -webkit-appearance: none;
      appearance: none;
      height: 2px;
      background: #E8E2D9;
      outline: none;
    }
    .klovo-range::-webkit-slider-thumb {
      -webkit-appearance: none; appearance: none;
      width: 22px; height: 22px;
      background: #0E4C8B;
      border: 3px solid #F7C948;
      border-radius: 50%;
      cursor: pointer;
    }
    .klovo-range::-moz-range-thumb {
      width: 22px; height: 22px;
      background: #0E4C8B;
      border: 3px solid #F7C948;
      border-radius: 50%;
      cursor: pointer;
    }
    .tag-chip {
      font-family: 'Jost', sans-serif;
      background: #FFFFFF;
      color: #272727;
      border: 1px solid #E8E2D9;
      transition: background 150ms, color 150ms, border-color 150ms;
      cursor: pointer;
    }
    .tag-chip.on {
      background: #0E4C8B;
      color: #FFFFFF;
      border-color: #0E4C8B;
    }
    .tag-chip:hover:not(.on) { border-color: #0E4C8B; }
  </style>

  <script is:inline define:vars={{ clientSets }}>
    (function () {
      const sets = clientSets;
      let wallFt = 8;
      let activeTag = 'all';

      const $ = (id) => document.getElementById(id);
      const fmtPrice = (n) => '$' + n.toLocaleString('en-US');

      function updateMatch() {
        // Exact matches at current wallFt
        let matches = sets.filter((s) => s.widthFt === wallFt);
        let fallback = '';
        if (matches.length === 0) {
          // No exact match — find nearest widthFt that has sets
          const widths = [...new Set(sets.map((s) => s.widthFt))];
          const nearestFt = widths.slice().sort((a, b) => Math.abs(a - wallFt) - Math.abs(b - wallFt))[0];
          matches = sets.filter((s) => s.widthFt === nearestFt);
          fallback = `No ${wallFt} ft sets — showing closest (${nearestFt} ft)`;
        }
        const matchIds = new Set(matches.map((m) => m.id));
        document.querySelectorAll('.match-card').forEach((card) => {
          const w = Number(card.getAttribute('data-match-width'));
          const visible = matches.some((m) => m.widthFt === w);
          card.classList.toggle('hidden', !visible);
        });
        $('match-count').textContent = matches.length;
        $('match-ft').textContent = wallFt;
        const fb = $('match-fallback');
        if (fallback) { fb.textContent = fallback; fb.classList.remove('hidden'); }
        else { fb.classList.add('hidden'); }
      }

      function updateTicks() {
        document.querySelectorAll('#wall-ft-ticks span').forEach((el) => {
          const active = Number(el.getAttribute('data-ft')) === wallFt;
          el.classList.toggle('text-klovo-blue', active);
          el.classList.toggle('font-semibold', active);
        });
      }

      function filterGrid() {
        let visible = 0;
        document.querySelectorAll('.set-card').forEach((card) => {
          const tags = (card.getAttribute('data-tags') || '').split(',').filter(Boolean);
          const show = activeTag === 'all' || tags.includes(activeTag);
          card.classList.toggle('hidden', !show);
          if (show) visible++;
        });
        $('grid-count').textContent = visible;
        $('empty-state').classList.toggle('hidden', visible !== 0);
      }

      $('wall-ft-input').addEventListener('input', (e) => {
        wallFt = Number(e.target.value);
        $('wall-ft-label').textContent = wallFt;
        updateTicks();
        updateMatch();
      });

      document.querySelectorAll('#tag-filters .tag-chip').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#tag-filters .tag-chip').forEach((b) => b.classList.remove('on'));
          btn.classList.add('on');
          activeTag = btn.getAttribute('data-tag');
          filterGrid();
        });
      });

      updateMatch();
    })();
  </script>
</BaseLayout>
