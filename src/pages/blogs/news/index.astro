---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft && !data.canonical)).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
);
---

<BaseLayout
  title="News & Guides"
  description="Garage storage guides, cabinet comparisons, and real makeover stories from Klovo."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-3">News & Guides</h1>
      <p class="text-lg text-gray-600">Buyer guides, real comparisons, and garage makeovers.</p>
    </header>

    <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <li class="flex flex-col border rounded-lg overflow-hidden hover:shadow-md transition">
          <a href={`/blogs/news/${post.id}`} class="flex flex-col h-full">
            {post.data.image && (
              <img
                src={post.data.image}
                alt={post.data.imageAlt || post.data.title}
                class="w-full aspect-[16/9] object-cover"
                loading="lazy"
              />
            )}
            <div class="p-5 flex flex-col flex-1">
              <h2 class="text-xl font-semibold mb-2 leading-snug">{post.data.title}</h2>
              <p class="text-sm text-gray-600 mb-4 flex-1">{post.data.description}</p>
              <time class="text-xs text-gray-500" datetime={new Date(post.data.date).toISOString()}>
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
