---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft && !data.canonical)).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
);
---

<PageLayout
  title="From the Workshop — Klovo Garage Blog"
  description="Garage storage guides, cabinet comparisons, and real makeover stories from Klovo."
  keywords="garage storage guide, garage cabinet comparison, garage makeover, modular garage cabinets, Klovo blog"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">From the Workshop</span>
      <h1 class="page-h1">Garage knowledge,<br/><em>straight from us.</em></h1>
      <p class="page-lede">Buyer guides, real comparisons, and garage makeovers. No filler.</p>
    </div>
  </section>

  <!-- Journal Grid -->
  <section class="section section--cream">
    <div class="container">
      {posts.length === 0 ? (
        <p style="font-family: var(--sans); color: var(--muted); font-size: 16px;">No posts yet. Check back soon.</p>
      ) : (
        <div class="journal-grid">
          {posts.map((post) => (
            <article class="journal-card">
              {post.data.image && (
                <a href={`/blogs/news/${post.id}`} class="journal-card-img-wrap" tabindex="-1" aria-hidden="true">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    class="journal-card-img"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="journal-card-body">
                <div class="journal-card-meta">
                  <time datetime={new Date(post.data.date).toISOString()}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  {post.data.tags && post.data.tags[0] && (
                    <>
                      <span class="journal-card-dot" aria-hidden="true"></span>
                      <span>{post.data.tags[0]}</span>
                    </>
                  )}
                </div>
                <h2 class="journal-card-title">
                  <a href={`/blogs/news/${post.id}`}>{post.data.title}</a>
                </h2>
                {post.data.description && (
                  <p class="journal-card-blurb">{post.data.description}</p>
                )}
                <a href={`/blogs/news/${post.id}`} class="journal-card-link">Read article &rarr;</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA Band -->
  <section class="page-cta-band">
    <div class="container">
      <span class="eyebrow" style="color: rgba(244,236,219,0.55);">Ready to Upgrade</span>
      <h2 class="h-final">Find the set that fits<br/><em>your garage.</em></h2>
      <p>15+ pre-designed sets. One for how you actually use the space.</p>
      <div class="page-cta-btns">
        <a href="/sets/" class="btn btn--primary">View sets &rarr;</a>
        <a href="/where-to-buy/" class="btn btn--ghost btn--ghost--dark">Find a retailer</a>
      </div>
    </div>
  </section>

</PageLayout>
