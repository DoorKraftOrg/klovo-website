---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const publishedISO = new Date(post.data.date).toISOString();
const canonical = post.data.canonical
  ? new URL(post.data.canonical, Astro.site).href
  : new URL(Astro.url.pathname, Astro.site).href;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: post.data.image ? new URL(post.data.image, Astro.site).href : undefined,
  datePublished: publishedISO,
  author: { '@type': 'Person', name: post.data.author },
  publisher: {
    '@type': 'Organization',
    name: 'Klovo',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.klovo.com/images/klovo-logo-official.png',
    },
  },
  mainEntityOfPage: canonical,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image}
  canonical={canonical}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <meta slot="head" property="article:published_time" content={publishedISO} />
  <meta slot="head" property="article:author" content={post.data.author} />
  {post.data.tags.map((tag: string) => (
    <meta slot="head" property="article:tag" content={tag} />
  ))}

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-sm mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:underline">Home</a>
      <span class="mx-2">/</span>
      <a href="/blogs/news" class="hover:underline">News</a>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">{post.data.title}</h1>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-600">
        <time datetime={publishedISO}>
          {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{post.data.author}</span>
      </div>
      {post.data.tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <li class="text-xs bg-gray-100 rounded-full px-3 py-1">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.imageAlt || post.data.title}
        class="w-full rounded-lg mb-8"
        loading="eager"
      />
    )}

    <div class="prose prose-lg max-w-none blog-body">
      <Content />
    </div>

    <footer class="mt-12 pt-8 border-t">
      <a href="/blogs/news" class="inline-block text-klovo-blue hover:underline">← Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  .blog-body h2 { font-size: 1.75rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; }
  .blog-body h3 { font-size: 1.35rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; }
  .blog-body p { margin-bottom: 1rem; line-height: 1.75; }
  .blog-body ul, .blog-body ol { margin-left: 1.5rem; margin-bottom: 1rem; }
  .blog-body ul { list-style: disc; }
  .blog-body ol { list-style: decimal; }
  .blog-body li { margin-bottom: 0.35rem; }
  .blog-body a { color: #0057ff; text-decoration: underline; }
  .blog-body img { border-radius: 0.5rem; margin: 1.5rem 0; }
  .blog-body table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
  .blog-body th, .blog-body td { border: 1px solid #e5e7eb; padding: 0.5rem 0.75rem; text-align: left; }
  .blog-body th { background: #f9fafb; font-weight: 600; }
  .blog-body blockquote { border-left: 4px solid #e5e7eb; padding-left: 1rem; font-style: italic; color: #4b5563; margin: 1.5rem 0; }
</style>
