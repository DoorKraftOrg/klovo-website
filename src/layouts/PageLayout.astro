---
import '../styles/homepage-v5.css';
import '../styles/page-v5.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  keywords?: string;
}

const {
  title = 'Klovo | Cabinet sets for the modern garage',
  description = 'Modular garage cabinet sets from 2 to 16 ft. DIY GlideLock assembly in under an hour. 500 lbs per cabinet, push-to-open, engineered wood. 100% Made in USA.',
  ogImage = '/images/og-default.jpg',
  canonical,
  keywords,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}

    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts: Newsreader (serif) + Geist (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,300;1,6..72,400;1,6..72,500;1,6..72,600&family=Geist:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Klovo" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@KlovoStorage" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Klovo",
      "url": "https://www.klovo.com",
      "logo": "https://www.klovo.com/images/klovo-logo-official.png",
      "description": "Premium garage cabinets with fast assembly. Scratch-resistant, moisture-proof. Built in Georgia.",
      "sameAs": [
        "https://www.instagram.com/klovostorage/",
        "https://x.com/KlovoStorage",
        "https://www.linkedin.com/company/klovo/"
      ],
      "parentOrganization": {
        "@type": "Organization",
        "name": "Door Kraft"
      }
    })} />

    <slot name="head" />
  </head>
  <body class="page-layout">
    <a href="#main-content" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;" onfocus="this.style.cssText='position:fixed;top:1rem;left:1rem;z-index:9999;padding:.5rem 1rem;background:#1F1B14;color:#F4ECDB;border-radius:4px;font-size:.875rem;font-weight:600;'">Skip to content</a>

    <!-- STICKY NAV -->
    <nav class="nav" id="site-nav">
      <a href="/" class="nav-logo" aria-label="Klovo home">
        <img src="/images/klovo-logo-official.png" alt="Klovo" />
      </a>
      <div class="nav-links" id="nav-links">
        <a href="/sets/">Sets</a>
        <a href="/assembly/">Assembly</a>
        <a href="/specs/">Specs</a>
        <a href="/gallery/">Gallery</a>
        <a href="/about/">About</a>
        <a href="/for-retailers/">For Retailers</a>
      </div>
      <a href="/where-to-buy/" class="nav-cta">Where to Buy</a>
      <button class="nav-burger" id="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
        <i></i><i></i><i></i>
      </button>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <!-- DARK FOOTER -->
    <footer class="footer">
      <div class="container">
        <div class="footer-top">
          <div class="footer-brand">
            <img src="/images/klovo-logo-official.png" alt="Klovo" class="footer-logo" />
            <p class="footer-tag">Cabinet sets for the modern garage. <br/>Made in the USA — factory in Georgia.</p>
            <div class="footer-social">
              <a href="https://www.instagram.com/klovostorage/" target="_blank" rel="noopener noreferrer" aria-label="Klovo on Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="https://www.tiktok.com/@klovostorage" target="_blank" rel="noopener noreferrer" aria-label="Klovo on TikTok">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.7a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
              </a>
              <a href="https://x.com/KlovoStorage" target="_blank" rel="noopener noreferrer" aria-label="Klovo on X">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://www.facebook.com/klovostorage" target="_blank" rel="noopener noreferrer" aria-label="Klovo on Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            </div>
          </div>
          <div class="footer-cols">
            <div>
              <div class="footer-h">Shop</div>
              <a href="/sets/">All Sets</a>
              <a href="/assembly/">Assembly</a>
              <a href="/specs/">Specs</a>
              <a href="/gallery/">Gallery</a>
              <a href="/where-to-buy/">Where to Buy</a>
            </div>
            <div>
              <div class="footer-h">Company</div>
              <a href="/about/">About</a>
              <a href="/for-retailers/">For Retailers</a>
              <a href="/blogs/news/">Blog</a>
              <a href="/contact/">Contact</a>
              <a href="/faq/">FAQ</a>
            </div>
            <div>
              <div class="footer-h">Support</div>
              <a href="/warranty/">Warranty</a>
              <a href="/contact/">Help</a>
            </div>
            <div class="footer-news">
              <div class="footer-h">Stay in the loop</div>
              <p class="footer-news-tag">Garage tips, new sets, the occasional dad joke.</p>
              <form class="footer-news-form" onsubmit="event.preventDefault();">
                <input type="email" placeholder="your email" aria-label="email" />
                <button type="submit">Join</button>
              </form>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; 2026 Klovo Storage by Door Kraft. All rights reserved.</span>
          <span class="footer-bottom-links">
            <a href="/warranty/">Warranty</a> &middot; <a href="/pages/privacy-policy/">Privacy</a> &middot; <a href="/pages/terms-of-service/">Terms</a>
          </span>
        </div>
      </div>
    </footer>

    <style>
      .footer-social {
        display: flex;
        gap: 14px;
        margin-top: 16px;
        align-items: center;
      }
      .footer-social a {
        color: rgba(244,236,219,0.5);
        transition: color 0.2s;
        display: flex;
        align-items: center;
      }
      .footer-social a:hover {
        color: var(--amber);
      }
    </style>
    <script is:inline>
      (function () {
        // Mobile nav burger
        var burger = document.getElementById('nav-burger');
        var navLinks = document.getElementById('nav-links');
        if (burger && navLinks) {
          burger.addEventListener('click', function () {
            var isOpen = navLinks.style.display === 'flex';
            navLinks.style.display = isOpen ? '' : 'flex';
            navLinks.style.flexDirection = isOpen ? '' : 'column';
            navLinks.style.position = isOpen ? '' : 'absolute';
            navLinks.style.top = isOpen ? '' : '100%';
            navLinks.style.left = isOpen ? '' : '0';
            navLinks.style.right = isOpen ? '' : '0';
            navLinks.style.background = isOpen ? '' : 'var(--ink)';
            navLinks.style.padding = isOpen ? '' : '16px 24px 24px';
            navLinks.style.gap = isOpen ? '' : '0';
            navLinks.style.zIndex = isOpen ? '' : '100';
            burger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
          });
        }
      })();
    </script>
  </body>
</html>
