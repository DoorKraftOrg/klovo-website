---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  keywords?: string;
}

const {
  title,
  description = 'Modular garage cabinet sets from 2 to 16 ft. DIY GlideLock assembly in under an hour. 500 lbs per cabinet, push-to-open, engineered wood. 100% Made in USA.',
  ogImage = '/images/og-default.jpg',
  canonical,
  keywords,
} = Astro.props;

const siteTitle = title === 'Home'
  ? 'Klovo | Modular Garage Cabinets — DIY GlideLock Sets, Made in USA'
  : `${title} | Klovo`;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}

    <title>{siteTitle}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts: Jost + Orbitron from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&family=Orbitron:wght@700;900&family=Oxanium:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Klovo" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@KlovoStorage" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Klovo",
      "url": "https://www.klovo.com",
      "logo": "https://www.klovo.com/images/klovo-logo-official.png",
      "description": "Premium garage cabinets with fast assembly. Scratch-resistant, moisture-proof. Built in Georgia.",
      "sameAs": [
        "https://www.instagram.com/klovostorage/",
        "https://x.com/KlovoStorage",
        "https://www.linkedin.com/company/klovo/"
      ],
      "parentOrganization": {
        "@type": "Organization",
        "name": "Door Kraft"
      }
    })} />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-klovo-blue focus:text-pure-white focus:rounded focus:text-sm focus:font-semibold">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
